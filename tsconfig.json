{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuildinfo",
    "noEmit": true
  },
  "include": [
    "src/**/*",
    "scripts/**/*",
    "agents/**/*",
    "docs/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".swarm",
    ".claude"
  ]
}
