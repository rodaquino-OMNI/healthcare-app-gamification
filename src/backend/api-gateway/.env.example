# ==============================================
# API Gateway Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# ============================================
# Required Configuration
# ============================================
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
API_BASE_URL=http://localhost:4000

# ============================================
# Authentication
# ============================================
# JWT secret key - generate a strong random string (256-bit recommended)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Token expiration times
TOKEN_EXPIRATION=1h
REFRESH_TOKEN_EXPIRATION=7d

# JWT token issuer and audience
TOKEN_ISSUER=austa.com.br
TOKEN_AUDIENCE=austa-users

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=https://app.austa.com.br,http://localhost:3000
CORS_CREDENTIALS=true

# ============================================
# Rate Limiting
# ============================================
# Rate limit window in milliseconds (900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Maximum requests per IP per window
RATE_LIMIT_MAX=100

# Journey-specific rate limits
RATE_LIMIT_HEALTH=200
RATE_LIMIT_CARE=150
RATE_LIMIT_PLAN=100

# ============================================
# GraphQL Configuration
# ============================================
GRAPHQL_PLAYGROUND=true
GRAPHQL_DEBUG=true
GRAPHQL_SCHEMA_FILE=schema.gql

# ============================================
# Caching
# ============================================
# Cache TTL values (format: 5m, 1h, 15m, etc.)
CACHE_TTL_HEALTH=5m
CACHE_TTL_CARE=1m
CACHE_TTL_PLAN=15m
CACHE_TTL_DEFAULT=5m

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_REQUESTS=true
LOG_RESPONSES=true
LOG_PRETTY=true

# ============================================
# Tracing (Optional)
# ============================================
TRACING_ENABLED=false
TRACING_EXPORTER_ENDPOINT=http://localhost:4318

# ============================================
# Backend Service Endpoints
# ============================================
AUTH_SERVICE_URL=http://auth-service:3000
AUTH_SERVICE_TIMEOUT=5000

HEALTH_SERVICE_URL=http://health-service:3000
HEALTH_SERVICE_TIMEOUT=5000

CARE_SERVICE_URL=http://care-service:3000
CARE_SERVICE_TIMEOUT=5000

PLAN_SERVICE_URL=http://plan-service:3000
PLAN_SERVICE_TIMEOUT=5000

GAMIFICATION_SERVICE_URL=http://gamification-service:3000
GAMIFICATION_SERVICE_TIMEOUT=5000

NOTIFICATION_SERVICE_URL=http://notification-service:3000
NOTIFICATION_SERVICE_TIMEOUT=5000
