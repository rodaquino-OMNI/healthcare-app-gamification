# ==============================================
# Health Service Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# ============================================
# Required Configuration
# ============================================
NODE_ENV=development
PORT=3002
API_PREFIX=api/v1

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string (REQUIRED)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/health
DATABASE_SSL=false

# TimescaleDB Configuration (for time-series metrics)
TIMESCALE_ENABLED=false
METRICS_RETENTION_DAYS=730
METRICS_AGGREGATION_ENABLED=false
METRICS_AGGREGATION_INTERVALS=hour,day,week,month

# ============================================
# Caching - Redis
# ============================================
# Redis connection string (REQUIRED)
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600

# ============================================
# FHIR API Integration
# ============================================
FHIR_API_ENABLED=false
FHIR_API_URL=https://fhir-api.example.com
FHIR_API_AUTH_TYPE=oauth2
FHIR_API_TIMEOUT=10000

# FHIR OAuth2 Authentication
FHIR_API_CLIENT_ID=your-fhir-client-id
FHIR_API_CLIENT_SECRET=your-fhir-client-secret
FHIR_API_SCOPE=launch/patient patient/read
FHIR_API_TOKEN_URL=https://fhir-auth.example.com/token

# FHIR Basic Authentication (alternative to OAuth2)
FHIR_API_USERNAME=fhir-username
FHIR_API_PASSWORD=fhir-password

# ============================================
# Wearables Integration
# ============================================
WEARABLES_SYNC_ENABLED=false
WEARABLES_SUPPORTED=googlefit,healthkit,fitbit
WEARABLES_SYNC_INTERVAL=15
WEARABLES_MAX_SYNC_DAYS=30

# Google Fit Configuration
GOOGLEFIT_CLIENT_ID=your-googlefit-client-id
GOOGLEFIT_CLIENT_SECRET=your-googlefit-client-secret

# Apple HealthKit Configuration
HEALTHKIT_TEAM_ID=your-healthkit-team-id
HEALTHKIT_KEY_ID=your-healthkit-key-id
HEALTHKIT_PRIVATE_KEY=your-healthkit-private-key-content

# Fitbit Configuration
FITBIT_CLIENT_ID=your-fitbit-client-id
FITBIT_CLIENT_SECRET=your-fitbit-client-secret

# ============================================
# Health Goals
# ============================================
HEALTH_GOALS_MAX_ACTIVE=10

# ============================================
# Health Insights & Analytics
# ============================================
HEALTH_INSIGHTS_ENABLED=false
HEALTH_INSIGHTS_GENERATION_INTERVAL=24
HEALTH_INSIGHTS_MODELS_PATH=./models/health-insights

# ============================================
# Medical History
# ============================================
MEDICAL_HISTORY_MAX_EVENTS=1000

# ============================================
# Event Streaming - Kafka
# ============================================
EVENTS_KAFKA_ENABLED=false
EVENTS_KAFKA_BROKERS=localhost:9092
EVENTS_TOPIC_PREFIX=austa.health

# ============================================
# Cloud Storage - AWS S3
# ============================================
# S3 bucket name (REQUIRED)
STORAGE_S3_BUCKET=austa-health-storage
# AWS region (REQUIRED)
STORAGE_S3_REGION=us-east-1
# S3 prefix for health service objects
STORAGE_S3_PREFIX=health
