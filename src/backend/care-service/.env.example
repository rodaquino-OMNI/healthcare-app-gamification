# ==============================================
# Care Service Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# ==============================================
# Required Configuration
# ==============================================
NODE_ENV=development
CARE_SERVICE_PORT=3003
CARE_SERVICE_JWT_SECRET=your-256-bit-random-secret-key-here

# ==============================================
# Database Configuration
# ==============================================
CARE_SERVICE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/austa_care
CARE_SERVICE_DB_MAX_CONNECTIONS=10
CARE_SERVICE_DB_IDLE_TIMEOUT=30000
CARE_SERVICE_DB_SSL=false

# ==============================================
# Redis Configuration (Caching & Real-time)
# ==============================================
CARE_SERVICE_REDIS_URL=redis://localhost:6379
CARE_SERVICE_REDIS_TTL=3600
CARE_SERVICE_REDIS_PREFIX=care:

# ==============================================
# API Configuration
# ==============================================
CARE_SERVICE_API_PREFIX=api/v1

# ==============================================
# Authentication & OAuth
# ==============================================
CARE_SERVICE_JWT_EXPIRES=1h
CARE_SERVICE_OAUTH_AUTHORITY=https://auth.austa.com.br
CARE_SERVICE_OAUTH_CLIENT_ID=care-service
CARE_SERVICE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
CARE_SERVICE_OAUTH_AUDIENCE=api://care-service

# ==============================================
# Provider Systems Integration
# ==============================================
CARE_SERVICE_PROVIDERS_API_URL=https://providers-api.austa.com.br
CARE_SERVICE_PROVIDERS_API_KEY=your-providers-api-key
CARE_SERVICE_PROVIDERS_TIMEOUT=5000
CARE_SERVICE_PROVIDERS_CACHE_ENABLED=false
CARE_SERVICE_PROVIDERS_CACHE_TTL=300
CARE_SERVICE_PROVIDERS_RETRY_ATTEMPTS=3
CARE_SERVICE_PROVIDERS_RETRY_DELAY=1000

# ==============================================
# Appointment Scheduling
# ==============================================
CARE_SERVICE_MAX_ADVANCE_DAYS=90
CARE_SERVICE_APPOINTMENT_REMINDER_SCHEDULE=24h,1h
CARE_SERVICE_DEFAULT_APPOINTMENT_DURATION=30
CARE_SERVICE_CANCELLATION_POLICY_ENABLED=true
CARE_SERVICE_MIN_CANCELLATION_HOURS=24
CARE_SERVICE_CANCELLATION_XP_LOSS=50
CARE_SERVICE_AVAILABILITY_BUFFER=15

# ==============================================
# Telemedicine Configuration
# ==============================================
CARE_SERVICE_TELEMEDICINE_ENABLED=true
CARE_SERVICE_TELEMEDICINE_PROVIDER=agora
CARE_SERVICE_AGORA_APP_ID=your-agora-app-id
CARE_SERVICE_AGORA_APP_CERTIFICATE=your-agora-app-certificate
CARE_SERVICE_AGORA_TOKEN_EXPIRATION=3600
CARE_SERVICE_TELEMEDICINE_RECORDING=false
CARE_SERVICE_TELEMEDICINE_RECORDING_BUCKET=austa-telemedicine-recordings
CARE_SERVICE_TELEMEDICINE_RECORDING_REGION=sa-east-1
CARE_SERVICE_RECORDING_RETENTION_DAYS=90
CARE_SERVICE_TELEMEDICINE_MIN_BITRATE=350000
CARE_SERVICE_TELEMEDICINE_MIN_FRAMERATE=15
CARE_SERVICE_TELEMEDICINE_CONNECTION_TIMEOUT=30000
CARE_SERVICE_TELEMEDICINE_DEFAULT_DURATION=20
CARE_SERVICE_TELEMEDICINE_MAX_DURATION=60
CARE_SERVICE_TELEMEDICINE_WARNING_TIME=5

# ==============================================
# Medication Tracking
# ==============================================
CARE_SERVICE_MEDICATION_REMINDERS=true
CARE_SERVICE_MEDICATION_DEFAULT_REMINDER_TIME=1h,0h
CARE_SERVICE_MEDICATION_ADHERENCE_THRESHOLD=0.8
CARE_SERVICE_REFILL_REMINDER_DAYS=7
CARE_SERVICE_MAX_MISSED_DOSES=3
CARE_SERVICE_DOSE_WINDOW_MINUTES=60

# ==============================================
# Treatment Plans
# ==============================================
CARE_SERVICE_TREATMENT_REMINDERS=true
CARE_SERVICE_TREATMENT_PROGRESS_FREQUENCY=daily
CARE_SERVICE_TREATMENT_AT_RISK_THRESHOLD=0.6
CARE_SERVICE_TREATMENT_ON_TRACK_THRESHOLD=0.8
CARE_SERVICE_TREATMENT_MISSED_ACTIVITIES=3
CARE_SERVICE_TREATMENT_MISSED_APPOINTMENTS=1

# ==============================================
# Symptom Checker
# ==============================================
CARE_SERVICE_SYMPTOMS_CHECKER_ENABLED=true
CARE_SERVICE_SYMPTOMS_CHECKER_PROVIDER=internal
CARE_SERVICE_SYMPTOMS_CHECKER_API_URL=https://symptoms-api.austa.com.br
CARE_SERVICE_SYMPTOMS_CHECKER_API_KEY=your-symptoms-api-key
CARE_SERVICE_SYMPTOMS_CHECKER_TIMEOUT=10000
CARE_SERVICE_EMERGENCY_SYMPTOMS=chest_pain,difficulty_breathing,severe_bleeding
CARE_SERVICE_SYMPTOMS_UPDATE_FREQUENCY=weekly

# ==============================================
# Notification Service Integration
# ==============================================
CARE_SERVICE_NOTIFICATIONS_URL=http://notification-service:3006
CARE_SERVICE_NOTIFICATIONS_API_KEY=your-notifications-api-key
CARE_SERVICE_DEFAULT_NOTIFICATION_CHANNEL=push,email
CARE_SERVICE_NOTIFICATION_THROTTLING=true
CARE_SERVICE_MAX_NOTIFICATIONS_HOUR=5
CARE_SERVICE_MAX_NOTIFICATIONS_DAY=20
CARE_SERVICE_APPOINTMENT_REMINDER_TEMPLATE=care-appointment-reminder
CARE_SERVICE_APPOINTMENT_CONFIRMATION_TEMPLATE=care-appointment-confirmation
CARE_SERVICE_MEDICATION_REMINDER_TEMPLATE=care-medication-reminder
CARE_SERVICE_TREATMENT_UPDATE_TEMPLATE=care-treatment-update

# ==============================================
# Gamification Integration
# ==============================================
CARE_SERVICE_GAMIFICATION_ENABLED=true
CARE_SERVICE_GAMIFICATION_URL=http://gamification-service:3005
CARE_SERVICE_GAMIFICATION_API_KEY=your-gamification-api-key
CARE_SERVICE_POINTS_APPOINTMENT_BOOKED=10
CARE_SERVICE_POINTS_APPOINTMENT_ATTENDED=50
CARE_SERVICE_POINTS_TELEMEDICINE_COMPLETED=50
CARE_SERVICE_POINTS_MEDICATION_PERFECT_WEEK=100
CARE_SERVICE_POINTS_TREATMENT_MILESTONE=75

# ==============================================
# Pharmacy Integration
# ==============================================
CARE_SERVICE_PHARMACY_INTEGRATION=false
CARE_SERVICE_PHARMACY_API_URL=https://pharmacy-api.austa.com.br
CARE_SERVICE_PHARMACY_API_KEY=your-pharmacy-api-key
CARE_SERVICE_PHARMACY_TIMEOUT=5000
CARE_SERVICE_PHARMACY_CACHE_ENABLED=true
CARE_SERVICE_PHARMACY_CACHE_TTL=3600

# ==============================================
# Emergency Services Integration
# ==============================================
CARE_SERVICE_EMERGENCY_INTEGRATION=false
CARE_SERVICE_EMERGENCY_API_URL=https://emergency-api.austa.com.br
CARE_SERVICE_EMERGENCY_API_KEY=your-emergency-api-key
CARE_SERVICE_EMERGENCY_NUMBER=192

# ==============================================
# Logging & Monitoring
# ==============================================
CARE_SERVICE_LOG_LEVEL=info
CARE_SERVICE_LOG_FORMAT=json
CARE_SERVICE_REQUEST_LOGGING=true
CARE_SERVICE_SENSITIVE_DATA_FIELDS=password,token,healthData

# ==============================================
# Feature Flags
# ==============================================
CARE_SERVICE_ENABLE_SYMPTOMS_CHECKER=true
CARE_SERVICE_ENABLE_TREATMENT_TRACKING=true
CARE_SERVICE_ENABLE_EMERGENCY_ACCESS=false
CARE_SERVICE_ENABLE_VIRTUAL_WAITING_ROOM=false
CARE_SERVICE_ENABLE_PROVIDER_RATINGS=true
CARE_SERVICE_ENABLE_DOCUMENT_SHARING=true
CARE_SERVICE_ENABLE_FOLLOW_UP_SUGGESTIONS=true
