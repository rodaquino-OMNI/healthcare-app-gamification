# ==========================================
# AUSTA Healthcare SuperApp - Staging Environment
# Copy this file to .env.staging and fill in real values.
# NEVER commit .env.staging to source control.
# ==========================================

# --- General ---
NODE_ENV=staging
IMAGE_TAG=latest
GITHUB_OWNER=austa-superapp
LOG_LEVEL=info

# --- Database ---
# Full DSN used by all services; each service appends ?schema=<name>
DATABASE_URL=postgresql://austa_staging:CHANGE_ME@postgres:5432/austa_staging
POSTGRES_USER=austa_staging
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=austa_staging

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# --- Auth / Security ---
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_256BIT
JWT_EXPIRY=3600

# Generate with: openssl rand -hex 32  (must be 32 bytes for AES-256)
PHI_ENCRYPTION_KEY=CHANGE_ME_GENERATE_AES_256_KEY

# --- Service Ports ---
API_GATEWAY_PORT=4000
AUTH_SERVICE_PORT=3001
HEALTH_SERVICE_PORT=3002
CARE_SERVICE_PORT=3003
PLAN_SERVICE_PORT=3004
GAMIFICATION_ENGINE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006

# --- Kafka ---
KAFKA_BROKERS=kafka:9092

# --- CORS ---
# Comma-separated list of allowed origins (web + mobile dev ports)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# --- Service URLs (used by api-gateway to route requests) ---
AUTH_SERVICE_URL=http://auth-service:3001
HEALTH_SERVICE_URL=http://health-service:3002
CARE_SERVICE_URL=http://care-service:3003
PLAN_SERVICE_URL=http://plan-service:3004
GAMIFICATION_ENGINE_URL=http://gamification-engine:3005
NOTIFICATION_SERVICE_URL=http://notification-service:3006

# --- Observability (optional — leave empty to disable) ---
SENTRY_DSN=
DATADOG_API_KEY=
