# ==============================================
# Auth Service Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# ============================================
# Required Configuration
# ============================================
NODE_ENV=development
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_API_PREFIX=api/v1

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string
AUTH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth
DATABASE_SSL=false
DATABASE_MAX_CONNECTIONS=20
DATABASE_IDLE_TIMEOUT=30000

# ============================================
# Authentication - JWT
# ============================================
# JWT secret key - generate a strong random string (256-bit recommended)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Token expiration times
JWT_ACCESS_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# JWT token issuer and audience
JWT_ISSUER=austa.com.br
JWT_AUDIENCE=austa-users

# ============================================
# OAuth Configuration - Google
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback
GOOGLE_AUTH_ENABLED=false

# ============================================
# OAuth Configuration - Facebook
# ============================================
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/v1/auth/facebook/callback
FACEBOOK_AUTH_ENABLED=false

# ============================================
# OAuth Configuration - Apple
# ============================================
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=your-apple-private-key-content
APPLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/apple/callback
APPLE_AUTH_ENABLED=false

# ============================================
# Multi-Factor Authentication (MFA)
# ============================================
MFA_ENABLED=true
MFA_ISSUER=AUSTA SuperApp
MFA_CODE_EXPIRATION=300
MFA_WINDOW_SIZE=1

# MFA Providers
SMS_PROVIDER=twilio
EMAIL_MFA_ENABLED=false
SMS_MFA_ENABLED=false
TOTP_MFA_ENABLED=true

# ============================================
# Session Management
# ============================================
MAX_CONCURRENT_SESSIONS=5
SESSION_ABSOLUTE_TIMEOUT=43200
SESSION_INACTIVITY_TIMEOUT=1800
REMEMBER_ME_EXTENSION=2592000

# ============================================
# Password Policy
# ============================================
PASSWORD_MIN_LENGTH=10
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_HISTORY=5
PASSWORD_MAX_AGE=7776000
PASSWORD_LOCKOUT_THRESHOLD=5
PASSWORD_LOCKOUT_DURATION=1800

# ============================================
# Security - Rate Limiting
# ============================================
# Rate limit window in milliseconds (900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Maximum requests per IP per window
RATE_LIMIT_MAX=100

# ============================================
# Security - CORS
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000
# Comma-separated list of allowed HTTP methods
CORS_METHODS=GET,POST,PUT,DELETE,PATCH
CORS_CREDENTIALS=true

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_OUTPUT=false
LOG_FILE_PATH=./logs/auth-service.log

# ============================================
# Monitoring
# ============================================
MONITORING_ENABLED=false
METRICS_PATH=/metrics
