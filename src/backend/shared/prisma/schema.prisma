generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────────────────────

enum AppointmentType {
  IN_PERSON
  TELEMEDICINE
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum DeviceType {
  FITBIT
  APPLE_HEALTH
  GOOGLE_FIT
  SAMSUNG_HEALTH
  GARMIN
}

enum DeviceConnectionStatus {
  CONNECTED
  DISCONNECTED
  EXPIRED
  PENDING
  FAILED
}

enum GoalType {
  STEPS
  SLEEP
  WATER
  WEIGHT
  EXERCISE
  HEART_RATE
  BLOOD_PRESSURE
  BLOOD_GLUCOSE
  CUSTOM
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum MetricType {
  STEPS
  HEART_RATE
  WEIGHT
  BLOOD_PRESSURE_SYSTOLIC
  BLOOD_PRESSURE_DIASTOLIC
  BLOOD_GLUCOSE
  SLEEP
  OXYGEN_SATURATION
  BODY_TEMPERATURE
  RESPIRATORY_RATE
  CALORIES
  DISTANCE
  FLOORS
  ACTIVITY
  UNKNOWN
}

enum MetricSource {
  USER_INPUT
  GOOGLE_FIT
  HEALTH_KIT
  EXTERNAL_LAB
  CONNECTED_DEVICE
  CALCULATED
}

// ──────────────────────────────────────────────────────────────
// AUTH-SERVICE MODELS
// ──────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  cpf       String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  roles                Role[]
  appointments         Appointment[]
  medications          Medication[]
  telemedicinePatient  TelemedicineSession[] @relation("TelemedicinePatient")
  telemedicineProvider TelemedicineSession[] @relation("TelemedicineProvider")
  treatmentPlans       TreatmentPlan[]
  gameProfile          GameProfile?
  deviceConnections    DeviceConnection[]
  healthMetrics        HealthMetric[]
  medicalEvents        MedicalEvent[]
  plans                Plan[]
  claims               Claim[]

  @@index([email])
  @@map("users")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String
  journey     String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations (implicit many-to-many)
  permissions Permission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id          Int    @id @default(autoincrement())
  name        String
  description String

  // Relations (implicit many-to-many)
  roles Role[]

  @@map("permissions")
}

// ──────────────────────────────────────────────────────────────
// CARE-SERVICE MODELS
// ──────────────────────────────────────────────────────────────

model Appointment {
  id         String            @id @default(uuid())
  userId     String
  providerId String
  dateTime   DateTime
  type       AppointmentType
  status     AppointmentStatus @default(SCHEDULED)
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  // Relations
  user                 User                  @relation(fields: [userId], references: [id])
  provider             Provider              @relation(fields: [providerId], references: [id])
  telemedicineSessions TelemedicineSession[]

  @@index([userId])
  @@index([providerId])
  @@index([status])
  @@map("appointments")
}

model Provider {
  id                    String   @id @default(uuid())
  name                  String
  specialty             String
  location              String
  phone                 String
  email                 String
  telemedicineAvailable Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  appointments Appointment[]

  @@index([specialty])
  @@map("providers")
}

model Medication {
  id              String    @id @default(uuid())
  userId          String
  name            String
  dosage          Float
  frequency       String
  startDate       DateTime
  endDate         DateTime?
  reminderEnabled Boolean   @default(true)
  notes           String?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([active])
  @@map("medications")
}

model TelemedicineSession {
  id            String    @id @default(uuid())
  appointmentId String
  patientId     String
  providerId    String
  startTime     DateTime
  endTime       DateTime?
  status        String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  appointment Appointment @relation(fields: [appointmentId], references: [id])
  patient     User        @relation("TelemedicinePatient", fields: [patientId], references: [id])
  provider    User        @relation("TelemedicineProvider", fields: [providerId], references: [id])

  @@index([appointmentId])
  @@index([patientId])
  @@index([providerId])
  @@map("telemedicine_sessions")
}

model TreatmentPlan {
  id          String    @id @default(uuid())
  userId      String
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  progress    Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("treatment_plans")
}

// ──────────────────────────────────────────────────────────────
// GAMIFICATION-ENGINE MODELS
// ──────────────────────────────────────────────────────────────

model Achievement {
  id          String @id @default(uuid())
  title       String
  description String
  journey     String
  icon        String
  xpReward    Int

  // Relations
  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  profileId     String
  achievementId String
  progress      Int       @default(0)
  unlocked      Boolean   @default(false)
  unlockedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  profile     GameProfile @relation(fields: [profileId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@id([profileId, achievementId])
  @@index([achievementId])
  @@map("user_achievements")
}

model GameProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  level     Int      @default(1)
  xp        Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User              @relation(fields: [userId], references: [id])
  achievements UserAchievement[]
  quests       UserQuest[]
  rewards      UserReward[]

  @@index([userId])
  @@map("game_profiles")
}

model Quest {
  id          String @id @default(uuid())
  title       String
  description String
  journey     String
  icon        String
  xpReward    Int

  // Relations
  userQuests UserQuest[]

  @@map("quests")
}

model UserQuest {
  id        String   @id @default(uuid())
  profileId String
  questId   String
  progress  Int      @default(0)
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  profile GameProfile @relation(fields: [profileId], references: [id])
  quest   Quest       @relation(fields: [questId], references: [id])

  @@index([profileId])
  @@index([questId])
  @@map("user_quests")
}

model Reward {
  id          String @id @default(uuid())
  title       String
  description String
  xpReward    Int
  icon        String
  journey     String @default("global")

  // Relations
  userRewards UserReward[]

  @@map("rewards")
}

model UserReward {
  id        String   @id @default(uuid())
  profileId String
  rewardId  String
  earnedAt  DateTime @default(now())

  // Relations
  profile GameProfile @relation(fields: [profileId], references: [id])
  reward  Reward      @relation(fields: [rewardId], references: [id])

  @@index([profileId])
  @@index([rewardId])
  @@map("user_rewards")
}

model Rule {
  id        String @id @default(uuid())
  event     String
  condition String
  actions   Json   @default("[]")

  @@map("rules")
}

// ──────────────────────────────────────────────────────────────
// HEALTH-SERVICE MODELS
// ──────────────────────────────────────────────────────────────

model DeviceConnection {
  id           String                 @id @default(uuid())
  userId       String
  recordId     String
  deviceType   DeviceType
  deviceId     String?
  status       DeviceConnectionStatus @default(PENDING)
  lastSync     DateTime?
  authToken    String?
  refreshToken String?
  tokenExpiry  DateTime?
  metadata     Json?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([deviceType])
  @@index([status])
  @@map("device_connections")
}

model HealthGoal {
  id            String     @id @default(uuid())
  recordId      String
  type          GoalType
  title         String
  description   String?
  targetValue   Float
  unit          String
  currentValue  Float      @default(0)
  status        GoalStatus @default(ACTIVE)
  period        GoalPeriod
  startDate     DateTime   @default(now())
  endDate       DateTime?
  completedDate DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([recordId, type])
  @@index([status])
  @@index([period])
  @@map("health_goals")
}

model HealthMetric {
  id         String        @id @default(uuid())
  userId     String
  type       MetricType
  value      Float
  unit       String
  timestamp  DateTime
  source     MetricSource?
  notes      String?
  trend      Float?
  isAbnormal Boolean?
  metadata   Json?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([timestamp])
  @@map("health_metrics")
}

model MedicalEvent {
  id          String   @id @default(uuid())
  userId      String
  type        String
  title       String
  description String
  provider    String?
  location    String?
  date        DateTime
  documents   String[]
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([date])
  @@map("medical_events")
}

// ──────────────────────────────────────────────────────────────
// NOTIFICATION-SERVICE MODELS
// ──────────────────────────────────────────────────────────────

model Notification {
  id                    Int      @id @default(autoincrement())
  userId                String   @map("user_id")
  type                  String
  title                 String
  body                  String
  channel               String
  status                String
  journey               String?
  metadata              Json?
  // Gamification-specific fields (merged from GamificationNotification)
  achievementId         String?  @map("achievement_id")
  points                Int?
  badgeId               String?  @map("badge_id")
  level                 Int?
  gamificationEventType String?  @map("gamification_event_type")
  pointsEarned          Int?     @map("points_earned")
  newLevel              Int?     @map("new_level")
  showCelebration       Boolean? @default(false) @map("show_celebration")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@map("notifications")
}

model NotificationPreference {
  id                 Int      @id @default(autoincrement())
  userId             String   @map("user_id")
  pushEnabled        Boolean  @default(true) @map("push_enabled")
  emailEnabled       Boolean  @default(true) @map("email_enabled")
  smsEnabled         Boolean  @default(false) @map("sms_enabled")
  typePreferences    Json?
  journeyPreferences Json?    @map("journey_preferences")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("notification_preferences")
}

model NotificationTemplate {
  id         String   @id @default(uuid())
  templateId String   @map("template_id")
  language   String   @default("pt-BR")
  title      String
  body       String
  channels   String
  journey    String?
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([templateId])
  @@map("notification_templates")
}

// ──────────────────────────────────────────────────────────────
// PLAN-SERVICE MODELS
// ──────────────────────────────────────────────────────────────

model Plan {
  id              String   @id @default(uuid())
  userId          String
  planNumber      String
  type            String
  validityStart   DateTime
  validityEnd     DateTime
  coverageDetails Json?
  journey         String   @default("plan")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  claims    Claim[]
  coverages Coverage[]
  benefits  Benefit[]
  user      User       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("plans")
}

model Claim {
  id                     String    @id @default(uuid())
  userId                 String
  planId                 String
  type                   String
  amount                 Decimal   @db.Decimal(10, 2)
  status                 String    @default("submitted")
  submittedAt            DateTime  @default(now())
  approvedAt             DateTime?
  rejectedAt             DateTime?
  paidAt                 DateTime?
  processedAt            DateTime  @updatedAt
  procedureCode          String?
  diagnosisCode          String?
  serviceDate            DateTime?
  providerName           String?
  providerTaxId          String?
  procedureDescription   String?
  receiptUrl             String?
  additionalDocumentUrls String[]
  statusHistory          Json?
  notes                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Relations
  plan Plan @relation(fields: [planId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@map("claims")
}

model Benefit {
  id          String  @id @default(uuid())
  planId      String
  type        String
  description String
  limitations String?
  usage       String?

  // Relations
  plan Plan @relation(fields: [planId], references: [id])

  @@index([planId])
  @@map("benefits")
}

model Coverage {
  id          String   @id @default(uuid())
  planId      String
  type        String
  details     String
  limitations String?
  coPayment   Decimal  @default(0) @db.Decimal(5, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  plan Plan @relation(fields: [planId], references: [id])

  @@index([planId])
  @@map("coverages")
}

model Document {
  id         String   @id @default(uuid())
  entityId   String   @map("entity_id")
  entityType String   @map("entity_type")
  type       String
  filePath   String   @map("file_path")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([entityId, entityType])
  @@map("documents")
}

// ──────────────────────────────────────────────────────────────
// AUDIT MODEL
// ──────────────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid())
  userId       String
  action       String
  resourceType String
  resourceId   String?
  journeyId    String?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ──────────────────────────────────────────────────────────────
// CONSENT MODELS (LGPD)
// ──────────────────────────────────────────────────────────────

enum ConsentType {
  DATA_PROCESSING
  HEALTH_DATA_SHARING
  MARKETING
  RESEARCH
  TELEMEDICINE
  THIRD_PARTY_SHARING
}

enum ConsentStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model ConsentRecord {
  id             String        @id @default(uuid())
  userId         String
  consentType    ConsentType
  status         ConsentStatus @default(ACTIVE)
  purpose        String
  dataCategories String[]
  grantedAt      DateTime      @default(now())
  expiresAt      DateTime?
  revokedAt      DateTime?
  ipAddress      String?
  userAgent      String?
  version        Int           @default(1)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([userId])
  @@index([consentType])
  @@index([status])
  @@map("consent_records")
}
