{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": "..",
    "paths": {
      "@app/shared": ["shared/src"],
      "@app/shared/*": ["shared/src/*"],
      "@app/auth": ["auth-service/src"],
      "@app/auth/*": ["auth-service/src/*"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}