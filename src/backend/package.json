{
    "name": "austa-superapp-backend",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "shared",
        "api-gateway",
        "auth-service",
        "health-service",
        "care-service",
        "plan-service",
        "gamification-engine",
        "notification-service",
        "packages/*"
    ],
    "scripts": {
        "bootstrap": "lerna bootstrap",
        "build": "lerna run build",
        "clean": "lerna run clean",
        "format": "prettier --write \"**/*.{ts,js,json}\"",
        "lint": "eslint \"**/*.ts\" --fix",
        "test": "lerna run test",
        "test:e2e": "lerna run test:e2e",
        "test:cov": "lerna run test:cov",
        "start:dev": "lerna run start:dev --parallel",
        "start:api-gateway": "lerna run start:dev --scope=api-gateway",
        "start:auth-service": "lerna run start:dev --scope=auth-service",
        "start:health-service": "lerna run start:dev --scope=health-service",
        "start:care-service": "lerna run start:dev --scope=care-service",
        "start:plan-service": "lerna run start:dev --scope=plan-service",
        "start:gamification-engine": "lerna run start:dev --scope=gamification-engine",
        "start:notification-service": "lerna run start:dev --scope=notification-service",
        "docker:up": "docker-compose up -d",
        "docker:down": "docker-compose down",
        "db:migrate": "lerna run db:migrate",
        "db:seed": "node tools/scripts/seed-database.js",
        "generate:service": "node tools/generators/service-generator",
        "generate:docs": "node tools/scripts/generate-api-docs.js",
        "prepare": "husky install",
        "postinstall": "node ../scripts/apply-security-patches.js || true",
        "patch-security": "node tools/scripts/patch-axios.js"
    },
