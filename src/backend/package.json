{
  "name": "austa-superapp-backend",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "api-gateway",
    "auth-service",
    "health-service",
    "care-service",
    "plan-service",
    "gamification-engine",
    "notification-service"
  ],
  "scripts": {
    "bootstrap": "lerna bootstrap",
    "build": "lerna run build",
    "clean": "lerna run clean",
    "format": "prettier --write \"**/*.{ts,js,json}\"",
    "lint": "eslint \"**/*.ts\" --fix",
    "test": "lerna run test",
    "test:e2e": "lerna run test:e2e",
    "test:cov": "lerna run test:cov",
    "start:dev": "lerna run start:dev --parallel",
    "start:api-gateway": "lerna run start:dev --scope=api-gateway",
    "start:auth-service": "lerna run start:dev --scope=auth-service",
    "start:health-service": "lerna run start:dev --scope=health-service",
    "start:care-service": "lerna run start:dev --scope=care-service",
    "start:plan-service": "lerna run start:dev --scope=plan-service",
    "start:gamification-engine": "lerna run start:dev --scope=gamification-engine",
    "start:notification-service": "lerna run start:dev --scope=notification-service",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:migrate": "lerna run db:migrate",
    "db:seed": "node tools/scripts/seed-database.js",
    "generate:service": "node tools/generators/service-generator",
    "generate:docs": "node tools/scripts/generate-api-docs.js",
    "prepare": "husky install",
    "preinstall": "npx npm-force-resolutions",
    "postinstall": "node tools/scripts/patch-axios.js",
    "patch-security": "node tools/scripts/patch-axios.js"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.0",
    "@jest/globals": "^29.7.0",
    "@nestjs/cli": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "chalk": "^5.3.0",
    "change-case": "^5.4.0",
    "commander": "^11.1.0",
    "concurrently": "^8.2.2",
    "dotenv-cli": "^7.4.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-nestjs": "^1.2.3",
    "eslint-plugin-prettier": "^5.1.3",
    "glob": "^10.3.10",
    "husky": "^9.0.6",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.0",
    "lerna": "^8.0.2",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.4",
    "prisma": "^5.10.2",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.4",
    "swagger-jsdoc": "^6.2.8",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@nestjs/apollo": "^12.0.11",
    "@nestjs/axios": "^2.0.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/event-emitter": "^2.0.4",
    "@nestjs/graphql": "^12.0.11",
    "@nestjs/jwt": "^10.1.1",
    "@nestjs/mapped-types": "^2.0.4",
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-fastify": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/swagger": "^7.2.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^10.0.1",
    "@nestjs/websockets": "^10.3.0",
    "@opentelemetry/api": "^1.4.1",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.41.2",
    "@opentelemetry/sdk-node": "^0.41.1",
    "@opentelemetry/sdk-trace-base": "^1.15.2",
    "@prisma/client": "^5.10.2",
    "@sendgrid/client": "^8.1.0",
    "@sendgrid/mail": "^8.1.0",
    "agora-rtc-sdk-ng": "4.23.2",
    "axios": "^1.6.8",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cls-hooked": "^4.2.2",
    "compression": "^1.7.4",
    "date-fns": "^3.3.1",
    "eventemitter2": "^6.4.9",
    "express": "^4.18.2",
    "fhir-kit-client": "^1.8.0",
    "firebase-admin": "^12.0.0",
    "graphql": "^16.8.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.12.2",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "lodash": "^4.17.21",
    "nodemailer": "^6.9.11",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "passport-oauth2": "^1.7.0",
    "path": "^0.12.7",
    "pg": "^8.11.3",
    "redis": "^4.6.13",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.4",
    "twilio": "^4.22.0",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/austa/superapp.git"
  },
  "author": "AUSTA Health Technologies",
  "license": "UNLICENSED",
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,json}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "axios": "^1.6.8",
    "agora-rtc-sdk-ng": {
      "axios": "^1.6.8",
      "@agora-js/media": {
        "axios": "^1.6.8"
      },
      "@agora-js/report": {
        "axios": "^1.6.8"
      },
      "@agora-js/shared": {
        "axios": "^1.6.8"
      }
    }
  },
  "resolutions": {
    "axios": "1.6.8"
  }
}
