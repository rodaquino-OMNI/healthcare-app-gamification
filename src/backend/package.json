{
  "name": "austa-superapp-backend",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "api-gateway",
    "auth-service",
    "health-service",
    "care-service",
    "plan-service",
    "gamification-engine",
    "notification-service"
  ],
  "scripts": {
    "bootstrap": "lerna bootstrap",
    "build": "lerna run build",
    "clean": "lerna run clean",
    "format": "prettier --write \"**/*.{ts,js,json}\"",
    "lint": "eslint \"**/*.ts\" --fix",
    "test": "lerna run test",
    "test:e2e": "lerna run test:e2e",
    "test:cov": "lerna run test:cov",
    "start:dev": "lerna run start:dev --parallel",
    "start:api-gateway": "lerna run start:dev --scope=api-gateway",
    "start:auth-service": "lerna run start:dev --scope=auth-service",
    "start:health-service": "lerna run start:dev --scope=health-service",
    "start:care-service": "lerna run start:dev --scope=care-service",
    "start:plan-service": "lerna run start:dev --scope=plan-service",
    "start:gamification-engine": "lerna run start:dev --scope=gamification-engine",
    "start:notification-service": "lerna run start:dev --scope=notification-service",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:migrate": "lerna run db:migrate",
    "db:seed": "node tools/scripts/seed-database.js",
    "generate:service": "node tools/generators/service-generator",
    "generate:docs": "node tools/scripts/generate-api-docs.js",
    "prepare": "husky install"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.0",
    "@jest/globals": "^29.0.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^5.59.5",
    "@typescript-eslint/parser": "^5.59.5",
    "chalk": "^4.1.2",
    "commander": "^8.3.0",
    "change-case": "^4.1.2",
    "concurrently": "^8.0.1",
    "dotenv-cli": "^7.2.1",
    "eslint": "^8.40.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-nestjs": "^1.2.3",
    "eslint-plugin-prettier": "^4.2.1",
    "glob": "^8.1.0",
    "husky": "^8.0.3",
    "jest": "^29.5.0",
    "js-yaml": "^4.1.0",
    "lerna": "^6.6.2",
    "lint-staged": "^13.2.2",
    "prettier": "^2.8.8",
    "rimraf": "^5.0.0",
    "supertest": "^6.3.3",
    "swagger-jsdoc": "latest",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "@nestjs/apollo": "^12.0.0",
    "@nestjs/axios": "^1.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^2.0.0",
    "@nestjs/graphql": "^12.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/mapped-types": "^1.2.0",
    "@nestjs/microservices": "^10.0.0",
    "@nestjs/passport": "^9.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-fastify": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.0.0",
    "@nestjs/prisma": "^1.0.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/swagger": "^10.0.0",
    "@nestjs/throttler": "^4.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/websockets": "^10.0.0",
    "@opentelemetry/api": "^1.6.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^1.0.0",
    "@opentelemetry/sdk-node": "^1.0.0",
    "@opentelemetry/sdk-trace-base": "^1.0.0",
    "@prisma/client": "^5.4.2",
    "@sendgrid/client": "^8.0.0",
    "@sendgrid/mail": "^8.0.0",
    "agora-rtc-sdk-ng": "^4.18.2",
    "axios": "^1.4.0",
    "bcrypt": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cls-hooked": "^2.1.0",
    "compression": "^1.7.4",
    "date-fns": "^2.30.0",
    "eventemitter2": "^6.4.0",
    "express": "^4.18.2",
    "fhir-kit-client": "^4.0.0",
    "firebase-admin": "^11.11.0",
    "graphql": "^16.0.0",
    "handlebars": "^4.7.8",
    "helmet": "^6.0.0",
    "ioredis": "^5.0.0",
    "joi": "^17.9.1",
    "jsonwebtoken": "^9.0.0",
    "kafkajs": "^2.2.4",
    "lodash": "^4.17.21",
    "nodemailer": "^6.9.7",
    "passport-jwt": "^4.0.0",
    "passport-local": "^1.0.0",
    "passport-oauth2": "^1.6.0",
    "path": "^0.12.7",
    "pg": "^8.11.3",
    "redis": "^4.6.7",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.2",
    "twilio": "^4.19.0",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/austa/superapp.git"
  },
  "author": "AUSTA Health Technologies",
  "license": "UNLICENSED",
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,json}": [
      "prettier --write"
    ]
  }
}