        "fhir-kit-client": "^1.8.0",
        "firebase-admin": "^13.0.0",
        "graphql": "16.13.1",
        "graphql-ws": "^6.0.0",
        "handlebars": "^4.7.8",
        "helmet": "^8.0.0",
        "ioredis": "^5.10.0",
        "joi": "^18.0.0",
        "jsonwebtoken": "^9.0.3",
        "kafkajs": "^2.2.4",
        "lodash": "^4.17.23",
        "nodemailer": "^7.0.13",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "passport-oauth2": "^1.7.0",
        "path": "^0.12.7",
        "pg": "^8.20.0",
        "redis": "^5.0.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "socket.io": "^4.8.3",
        "twilio": "^4.22.0",
        "uuid": "^9.0.1",
        "@willsoto/nestjs-prometheus": "^6.0.1",
        "prom-client": "^15.1.0",
        "winston": "^3.19.0",
        "zod": "^3.25.76"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/austa/superapp.git"
    },
    "author": "AUSTA Health Technologies",
    "license": "UNLICENSED",
    "lint-staged": {
        "*.ts": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.{js,json}": [
            "prettier --write"
        ]
    }
}
