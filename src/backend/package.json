{
    "name": "austa-superapp-backend",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "clean": "turbo run clean",
        "format": "prettier --write \"**/*.{ts,js,json}\"",
        "lint": "eslint \"**/*.ts\" --fix",
        "test": "turbo run test",
        "test:e2e": "turbo run test:e2e",
        "test:cov": "turbo run test:cov",
        "start:dev": "turbo run start:dev --parallel",
        "start:api-gateway": "turbo run start:dev --filter=api-gateway",
        "start:auth-service": "turbo run start:dev --filter=auth-service",
        "start:health-service": "turbo run start:dev --filter=health-service",
        "start:care-service": "turbo run start:dev --filter=care-service",
        "start:plan-service": "turbo run start:dev --filter=plan-service",
        "start:gamification-engine": "turbo run start:dev --filter=gamification-engine",
        "start:notification-service": "turbo run start:dev --filter=notification-service",
        "docker:up": "docker compose -f ../../infrastructure/docker/docker-compose.dev.yml up -d",
        "docker:down": "docker compose -f ../../infrastructure/docker/docker-compose.dev.yml down",
        "db:migrate": "turbo run db:migrate",
        "db:seed": "node tools/scripts/seed-database.js",
        "generate:service": "node tools/generators/service-generator",
        "generate:docs": "node tools/scripts/generate-api-docs.js"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "devDependencies": {
        "@graphql-codegen/cli": "^5.0.7",
        "@jest/globals": "^29.7.0",
        "@nestjs/cli": "^11.0.17",
        "@nestjs/testing": "^11.0.0",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "chalk": "^5.3.0",
        "change-case": "^5.4.0",
        "commander": "^14.0.0",
        "concurrently": "^9.0.0",
        "dotenv-cli": "^11.0.0",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^10.0.0",
        "eslint-import-resolver-typescript": "^3.6.0",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-nestjs": "^1.2.3",
        "eslint-plugin-prettier": "^5.1.3",
        "husky": "^9.0.6",
        "jest": "^29.7.0",
        "js-yaml": "^4.1.0",
        "lint-staged": "^16.0.0",
        "prettier": "^3.2.4",
        "prisma": "^7.0.0",
        "rimraf": "^6.0.0",
        "supertest": "^7.0.0",
        "swagger-jsdoc": "^6.2.8",
        "ts-node": "^10.9.2",
        "typescript": "5.3.3"
    },
    "dependencies": {
        "@apollo/server": "^5.0.0",
        "@apollo/subgraph": "^2.13.1",
        "@apollo/usage-reporting-protobuf": "^4.0.0",
        "@apollo/utils.fetcher": "^3.0.0",
        "@nestjs/apollo": "^12.0.11",
        "@nestjs/axios": "^2.0.0",
        "@nestjs/common": "^11.0.16",
        "@nestjs/config": "^3.1.1",
        "@nestjs/core": "^11.0.16",
        "@nestjs/event-emitter": "^2.0.4",
        "@nestjs/graphql": "^12.0.11",
        "@nestjs/jwt": "^11.0.0",
        "@nestjs/mapped-types": "^2.0.4",
