# ==============================================
# Notification Service Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# ==============================================
# Required Configuration
# ==============================================
NODE_ENV=development
NOTIFICATION_PORT=3006
API_PREFIX=api

# ==============================================
# Database Configuration
# ==============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/austa_notifications

# ==============================================
# Redis Configuration
# ==============================================
REDIS_URL=redis://localhost:6379

# ==============================================
# Kafka Configuration
# ==============================================
KAFKA_BROKERS=localhost:9092

# ==============================================
# WebSocket Configuration
# ==============================================
WEBSOCKET_PORT=3004

# ==============================================
# Email Configuration
# ==============================================
EMAIL_FROM_ADDRESS=notifications@austa.com
EMAIL_FROM_NAME=AUSTA Notifications
EMAIL_ENABLED=true

# ==============================================
# SMS Configuration
# ==============================================
SMS_FROM_NUMBER=+55-your-sms-number
SMS_ENABLED=true

# ==============================================
# Push Notifications Configuration
# ==============================================
PUSH_ENABLED=true
FIREBASE_API_KEY=your-firebase-api-key

# ==============================================
# Notification Channels & Priority
# ==============================================
CHANNEL_PRIORITY=push,email,sms,in-app
INAPP_ENABLED=true
DEFAULT_JOURNEY=default

# ==============================================
# Retry & Expiration Settings
# ==============================================
MAX_RETRIES=3
RETRY_DELAY=1000
EXPIRATION_TIME=86400

# ==============================================
# Rate Limiting
# ==============================================
RATE_LIMIT_DEFAULT=100
