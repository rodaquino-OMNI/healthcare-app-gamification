{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@app/auth": ["../auth-service/src"],
      "@app/auth/*": ["../auth-service/src/*"],
      "@app/shared": ["../shared/src"],
      "@app/shared/*": ["../shared/src/*"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}