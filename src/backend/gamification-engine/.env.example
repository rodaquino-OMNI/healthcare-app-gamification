# ==============================================
# Gamification Engine Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control

# ==============================================
# Required Configuration
# ==============================================
NODE_ENV=development
PORT=3005
API_PREFIX=api

# ==============================================
# Kafka Configuration (Event Processing)
# ==============================================
KAFKA_CLIENT_ID=gamification-engine
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=gamification-consumer-group
KAFKA_TOPIC_HEALTH_EVENTS=health.events
KAFKA_TOPIC_CARE_EVENTS=care.events
KAFKA_TOPIC_PLAN_EVENTS=plan.events
KAFKA_TOPIC_USER_EVENTS=user.events
KAFKA_TOPIC_GAME_EVENTS=game.events
KAFKA_MAX_RETRIES=3
KAFKA_RETRY_INTERVAL=1000

# ==============================================
# Event Processing Configuration
# ==============================================
EVENT_PROCESSING_RATE=1000
EVENT_BATCH_SIZE=100
RULES_REFRESH_INTERVAL=60000

# ==============================================
# Points Configuration
# ==============================================
DEFAULT_POINT_HEALTH_METRIC_RECORDED=10
DEFAULT_POINT_APPOINTMENT_BOOKED=20
DEFAULT_POINT_APPOINTMENT_ATTENDED=50
DEFAULT_POINT_CLAIM_SUBMITTED=15
DEFAULT_POINT_GOAL_COMPLETED=100
MAX_POINTS_PER_DAY=1000
MAX_POINTS_PER_ACTION=500

# ==============================================
# Redis Configuration (Caching & State)
# ==============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=game:
ACHIEVEMENTS_TTL=3600
USER_PROFILE_TTL=300
LEADERBOARD_TTL=900
RULES_TTL=600

# ==============================================
# Database Configuration
# ==============================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/austa_gamification
DATABASE_SSL=false
DATABASE_LOGGING=false

# ==============================================
# Gamification Features
# ==============================================
CACHE_ENABLED=true
LEADERBOARD_UPDATE_INTERVAL=900000
LEADERBOARD_MAX_ENTRIES=100
ACHIEVEMENTS_NOTIFICATIONS_ENABLED=true
ACHIEVEMENTS_PROGRESS_TRACKING_ENABLED=true
ACHIEVEMENTS_MAX_CONCURRENT_QUESTS=5
REWARDS_EXPIRATION_DAYS=30
REWARDS_REDEMPTION_ENABLED=true
