{
    "name": "gamification-engine",
    "version": "1.0.0",
    "description": "AUSTA SuperApp Gamification Engine",
    "author": "AUSTA Health Technologies",
    "license": "UNLICENSED",
    "private": true,
    "scripts": {
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch -r tsconfig-paths/register",
        "start:debug": "nest start --debug --watch -r tsconfig-paths/register",
        "start:prod": "node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest --config jest.config.js",
        "test:watch": "jest --watch --config jest.config.js",
        "test:cov": "jest --coverage --config jest.config.js",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "db:migrate": "prisma migrate dev",
        "db:deploy": "prisma migrate deploy",
        "db:seed": "ts-node prisma/seed.ts",
        "prisma:generate": "prisma generate",
        "prisma:studio": "prisma studio"
    },
    "dependencies": {
        "@nestjs/apollo": "^12.0.11",
        "@nestjs/axios": "^2.0.0",
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^3.1.1",
        "@nestjs/core": "^11.0.0",
        "@nestjs/event-emitter": "^2.0.4",
        "@nestjs/graphql": "^12.0.11",
        "@nestjs/jwt": "^11.0.0",
        "@nestjs/mapped-types": "^2.0.4",
        "@nestjs/microservices": "^11.0.0",
        "@nestjs/platform-express": "^11.0.0",
        "@nestjs/schedule": "^4.0.0",
        "@nestjs/swagger": "^11.0.7",
        "@opentelemetry/api": "^1.4.1",
        "@opentelemetry/exporter-trace-otlp-grpc": "^0.213.0",
        "@opentelemetry/sdk-node": "^0.213.0",
        "@opentelemetry/sdk-trace-base": "^1.15.2",
        "@prisma/client": "^7.0.0",
        "axios": "1.13.6",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "compression": "^1.8.1",
        "date-fns": "^4.0.0",
        "expr-eval": "^2.0.2",
        "express": "^5.1.0",
        "graphql": "16.13.1",
        "helmet": "^8.0.0",
        "ioredis": "^5.10.0",
        "joi": "^18.0.0",
        "jsonwebtoken": "^9.0.3",
        "kafkajs": "^2.2.4",
        "lodash": "^4.17.21",
        "redis": "^5.0.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "uuid": "^9.0.1",
        "@willsoto/nestjs-prometheus": "^6.0.1",
        "prom-client": "^15.1.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.0",
        "@types/express": "^5.0.0",
        "@types/jest": "^29.5.12",
        "@types/node": "^20.11.30",
        "@types/supertest": "^6.0.2",
        "@typescript-eslint/eslint-plugin": "^7.3.1",
        "@typescript-eslint/parser": "^7.3.1",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^10.0.0",
        "eslint-plugin-prettier": "^5.1.3",
        "jest": "^29.7.0",
        "prettier": "^3.2.5",
        "prisma": "^7.0.0",
        "source-map-support": "^0.5.21",
        "supertest": "^6.3.4",
        "ts-jest": "^29.1.2",
        "ts-loader": "^9.5.1",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "5.9.3"
    }
