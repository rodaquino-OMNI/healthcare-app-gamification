require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

def ccache_enabled?(podfile_properties)
  # Environment variable takes precedence
  return ENV['USE_CCACHE'] == '1' if ENV['USE_CCACHE']

  # Fall back to Podfile properties
  podfile_properties['apple.ccacheEnabled'] == 'true'
end

ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] ||= podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']
ENV['RCT_USE_RN_DEP'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true'
ENV['RCT_USE_PREBUILT_RNCORE'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true'
ENV['RCT_HERMES_V1_ENABLED'] ||= '1' if podfile_properties['expo.useHermesV1'] == 'true'
platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'

prepare_react_native_project!

target 'AUSTASuperApp' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(\'expo/bin/autolinking\')',
      'expo-modules-autolinking',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => podfile_properties['ios.useFrameworks'].to_sym if podfile_properties['ios.useFrameworks']
  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => ccache_enabled?(podfile_properties),
    )

    # ---------------------------------------------------------------
    # Sentry SDK 8.41.0 patches for Xcode 16.3+ / 26.3+ (PRs #4917 & #4918)
    # Remove when @sentry/react-native upgrades to Sentry >= 8.46.0
    # ---------------------------------------------------------------

    # Patch 1 (PR #4918): std::vector<const T> is illegal per C++ standard;
    # newer libc++ enforces this via static_assert.
    sentry_header = File.join(
      installer.sandbox.root,
      'Sentry/Sources/Sentry/include/SentryThreadMetadataCache.hpp'
    )
    if File.exist?(sentry_header)
      content = File.read(sentry_header)
      patched = content.gsub(
        'std::vector<const ThreadHandleMetadataPair>',
        'std::vector<ThreadHandleMetadataPair>'
      )
      if content != patched
        File.chmod(0644, sentry_header)
        File.write(sentry_header, patched)
        puts "[Sentry patch] Removed const from std::vector in SentryThreadMetadataCache.hpp"
      end
    end

    # Patch 2 (PR #4917): Replace VLA via function call with static const size.
    # sentrycrashmc_contextSize() -> sentrycrashmc_contextSize (constant).
    sentry_ctx_header = File.join(
      installer.sandbox.root,
      'Sentry/Sources/SentryCrash/Recording/Tools/SentryCrashMachineContext.h'
    )
    if File.exist?(sentry_ctx_header)
      content = File.read(sentry_ctx_header)
      patched = content
      # Add Apple header include only if not already present (idempotent)
      if !patched.include?('SentryCrashMachineContext_Apple.h')
        patched = patched.gsub('#include "SentryCrashThread.h"', '#include "SentryCrashMachineContext_Apple.h"' + "\n" + '#include "SentryCrashThread.h"')
      end
      patched = patched.gsub('sentrycrashmc_contextSize()', 'sentrycrashmc_contextSize')
      patched = patched.gsub(/^int\nsentrycrashmc_contextSize\(void\);\n/, '')
      patched = patched.gsub("int sentrycrashmc_contextSize(void);\n", '')
      patched = patched.gsub("/** Get the internal size of a machine context.\n */\n", '') if !patched.include?('sentrycrashmc_contextSize(void)')
      if content != patched
        File.chmod(0644, sentry_ctx_header)
        File.write(sentry_ctx_header, patched)
        puts "[Sentry patch] Applied VLA fix in SentryCrashMachineContext.h"
      end
    end

    # Also remove the function definition in the .c file if present
    sentry_ctx_c = File.join(
      installer.sandbox.root,
      'Sentry/Sources/SentryCrash/Recording/Tools/SentryCrashMachineContext.c'
    )
    if File.exist?(sentry_ctx_c)
      content = File.read(sentry_ctx_c)
      patched = content.gsub(/\nint\nsentrycrashmc_contextSize\(void\)\n\{\n\s*return sizeof\(SentryCrashMachineContext\);\n\}\n/, "\n")
      if content != patched
        File.chmod(0644, sentry_ctx_c)
        File.write(sentry_ctx_c, patched)
        puts "[Sentry patch] Removed sentrycrashmc_contextSize() function from SentryCrashMachineContext.c"
      end
    end

    # Ensure SentryCrashMachineContext_Apple.h has the static const size
    sentry_apple_header = File.join(
      installer.sandbox.root,
      'Sentry/Sources/SentryCrash/Recording/Tools/SentryCrashMachineContext_Apple.h'
    )
    if File.exist?(sentry_apple_header)
      content = File.read(sentry_apple_header)
      if !content.include?('sentrycrashmc_contextSize') && content.include?('} SentryCrashMachineContext;')
        patched = content
          .gsub('#include <stdbool.h>', '#include <stdbool.h>' + "\n" + '#include <stddef.h>')
          .gsub("} SentryCrashMachineContext;\n", "} SentryCrashMachineContext;\n\nstatic const size_t sentrycrashmc_contextSize = sizeof(SentryCrashMachineContext);\n")
        if content != patched
          File.chmod(0644, sentry_apple_header)
          File.write(sentry_apple_header, patched)
          puts "[Sentry patch] Added static const sentrycrashmc_contextSize to SentryCrashMachineContext_Apple.h"
        end
      end
    end
  end
end
