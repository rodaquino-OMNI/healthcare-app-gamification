    <string>This app uses Bluetooth to connect with your health devices.</string>
    <key>NSCameraUsageDescription</key>
    <string>This app uses the camera to capture photos for health documentation and insurance claims.</string>
    <key>NSFaceIDUsageDescription</key>
    <string>This app uses Face ID to securely authenticate you.</string>
    <key>NSHealthShareUsageDescription</key>
