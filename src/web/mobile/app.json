{
    "name": "austa",
    "displayName": "AUSTA",
    "expo": {
        "name": "AUSTA SuperApp",
        "slug": "austa-superapp",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./src/assets/images/logo.png",
        "userInterfaceStyle": "automatic",
        "splash": {
            "image": "./src/assets/images/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#ffffff"
        },
        "assetBundlePatterns": ["**/*"],
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "br.com.austa.superapp",
            "buildNumber": "1",
            "googleServicesFile": "./GoogleService-Info.plist",
            "infoPlist": {
                "NSCameraUsageDescription": "This app uses the camera to capture photos for health documentation and insurance claims.",
                "NSPhotoLibraryUsageDescription": "This app accesses your photos to upload health documentation and insurance claims.",
                "NSHealthShareUsageDescription": "This app accesses your health data to provide personalized health insights and track your progress.",
                "NSHealthUpdateUsageDescription": "This app updates your health data to keep track of your health metrics and goals.",
                "NSFaceIDUsageDescription": "This app uses Face ID to securely authenticate you.",
                "NSBluetoothAlwaysUsageDescription": "This app uses Bluetooth to connect with your health devices.",
                "NSBluetoothPeripheralUsageDescription": "This app uses Bluetooth to connect with your health devices.",
                "UIBackgroundModes": ["fetch", "remote-notification"],
                "NSUserTrackingUsageDescription": "This app uses tracking to provide personalized health insights and measure campaign effectiveness.",
                "NSMicrophoneUsageDescription": "This app uses the microphone for telemedicine video calls.",
                "ITSAppUsesNonExemptEncryption": false
            },
            "config": {
                "usesNonExemptEncryption": false
            },
            "entitlements": {
                "com.apple.developer.applesignin": ["Default"],
                "com.apple.developer.healthkit": true,
                "com.apple.developer.healthkit.access": ["health-records"],
                "aps-environment": "production",
                "com.apple.developer.associated-domains": [
                    "applinks:app.austa.com.br",
                    "webcredentials:app.austa.com.br",
                    "activitycontinuation:app.austa.com.br"
                ]
            },
            "privacyManifests": {
                "NSPrivacyAccessedAPITypes": [
                    {
                        "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
                        "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
                    },
                    {
                        "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
                        "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
                    },
                    {
                        "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
                        "NSPrivacyAccessedAPITypeReasons": ["E174.1"]
                    }
                ],
                "NSPrivacyCollectedDataTypes": [
                    {
                        "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeHealthData",
                        "NSPrivacyCollectedDataTypeLinked": true,
                        "NSPrivacyCollectedDataTypeTracking": false,
                        "NSPrivacyCollectedDataTypePurposes": ["NSPrivacyCollectedDataTypePurposeAppFunctionality"]
                    },
                    {
                        "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeEmailAddress",
                        "NSPrivacyCollectedDataTypeLinked": true,
                        "NSPrivacyCollectedDataTypeTracking": false,
                        "NSPrivacyCollectedDataTypePurposes": ["NSPrivacyCollectedDataTypePurposeAppFunctionality"]
                    },
                    {
                        "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeName",
                        "NSPrivacyCollectedDataTypeLinked": true,
                        "NSPrivacyCollectedDataTypeTracking": false,
                        "NSPrivacyCollectedDataTypePurposes": ["NSPrivacyCollectedDataTypePurposeAppFunctionality"]
                    }
                ],
                "NSPrivacyTracking": false
            }
        },
        "android": {
            "adaptiveIcon": {
                "foregroundImage": "./src/assets/images/adaptive-icon.png",
                "backgroundColor": "#ffffff"
            },
            "package": "br.com.austa.superapp",
            "versionCode": 1,
            "permissions": [
                "CAMERA",
                "READ_EXTERNAL_STORAGE",
                "WRITE_EXTERNAL_STORAGE",
                "ACCESS_FINE_LOCATION",
                "ACCESS_COARSE_LOCATION",
                "BLUETOOTH",
                "BLUETOOTH_ADMIN",
                "INTERNET",
                "VIBRATE",
                "RECEIVE_BOOT_COMPLETED",
                "USE_BIOMETRIC",
                "USE_FINGERPRINT",
                "RECORD_AUDIO",
                "BLUETOOTH_SCAN",
                "BLUETOOTH_CONNECT",
                "POST_NOTIFICATIONS",
                "SCHEDULE_EXACT_ALARM"
            ],
            "googleServicesFile": "./google-services.json"
        },
        "web": {
            "favicon": "./src/assets/images/favicon.png"
        },
        "plugins": [
            "@react-native-firebase/app",
            "react-native-health",
            "react-native-biometrics",
            [
                "expo-notifications",
                {
                    "icon": "./src/assets/images/notification-icon.png",
                    "color": "#ffffff",
                    "sounds": ["./src/assets/sounds/notification.wav", "./src/assets/sounds/achievement.wav"]
                }
            ],
            "expo-apple-authentication",
            [
                "expo-tracking-transparency",
                {
                    "userTrackingPermission": "This app uses tracking to provide personalized health insights and measure campaign effectiveness."
                }
            ],
            [
                "expo-build-properties",
                {
                    "ios": {
                        "deploymentTarget": "15.0",
                        "useFrameworks": "static"
                    },
                    "android": {
                        "compileSdkVersion": 34,
                        "targetSdkVersion": 34,
                        "minSdkVersion": 24,
                        "buildToolsVersion": "34.0.0",
                        "kotlinVersion": "1.9.22",
                        "enableProguardInReleaseBuilds": true,
                        "enableShrinkResourcesInReleaseBuilds": true
                    }
                }
            ],
            "expo-dev-client"
        ],
        "notification": {
            "icon": "./src/assets/images/notification-icon.png",
            "color": "#ffffff",
            "androidMode": "default",
            "androidCollapsedTitle": "AUSTA SuperApp"
        },
        "updates": {
            "fallbackToCacheTimeout": 0,
            "url": "https://u.expo.dev/YOUR_EAS_PROJECT_ID_HERE"
        },
        "extra": {
            "eas": {
                "projectId": "YOUR_EAS_PROJECT_ID_HERE"
            }
        },
        "runtimeVersion": {
            "policy": "appVersion"
        }
    }
}
