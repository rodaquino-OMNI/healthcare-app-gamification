{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "target": "es2018",
        "lib": ["dom", "dom.iterable", "esnext"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "incremental": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"],
            "design-system/*": ["../design-system/src/*"],
            "shared/*": ["../shared/*"],
            "src/web/design-system/src/*": ["../design-system/src/*"],
            "src/web/shared/*": ["../shared/*"],
            "react": ["./node_modules/@types/react", "../node_modules/@types/react"],
            "react-dom": ["./node_modules/@types/react-dom", "../node_modules/@types/react-dom"],
            "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime", "../node_modules/@types/react/jsx-runtime"]
        },
        "typeRoots": ["./node_modules/@types", "../node_modules/@types"],
        "types": ["node", "react", "react-dom"],
        "noImplicitAny": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true
    },
    "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
    "exclude": ["node_modules", ".next", "out", "**/*.test.ts", "**/*.test.tsx", "**/*.stories.tsx"]
}
