{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./web/src/*"],
      "design-system/*": ["./design-system/src/*"],
      "shared/*": ["./shared/*"],
      "@design-system/*": ["./design-system/src/*"],
      "@components/*": ["./mobile/src/components/*"],
      "@screens/*": ["./mobile/src/screens/*"],
      "@navigation/*": ["./mobile/src/navigation/*"],
      "@hooks/*": ["./mobile/src/hooks/*"],
      "@utils/*": ["./mobile/src/utils/*"],
      "@api/*": ["./mobile/src/api/*"],
      "@context/*": ["./mobile/src/context/*"],
      "@assets/*": ["./mobile/src/assets/*"],
      "@constants/*": ["./mobile/src/constants/*"],
      "@i18n/*": ["./mobile/src/i18n/*"],
      "@shared/*": ["./shared/*"],
      "@austa/design-system": ["./design-system/src/index"],
      "@austa/design-system/*": ["./design-system/src/*"],
      "@austa/shared/*": ["./shared/*"],
      "@web/design-system/*": ["./design-system/*"],
      "@web/shared/*": ["./shared/*"],
      "@web/mobile/*": ["./mobile/src/*"],
      "@design-system/tokens/*": ["./design-system/src/tokens/*"],
      "@design-system/themes/*": ["./design-system/src/themes/*"],
      "@design-system/primitives/*": ["./design-system/src/primitives/*"],
      "@design-system/components/*": ["./design-system/src/components/*"],
      "@design-system/gamification/*": ["./design-system/src/gamification/*"],
      "@design-system/health/*": ["./design-system/src/health/*"],
      "@design-system/care/*": ["./design-system/src/care/*"],
      "@design-system/plan/*": ["./design-system/src/plan/*"],
      "@design-system/charts/*": ["./design-system/src/charts/*"]
    },
    "typeRoots": ["../../node_modules/@types", "./types"],
    "types": ["node", "react", "react-dom", "jest", "styled-components", "testing-library__jest-dom"]
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"],
  "exclude": ["node_modules"]
}