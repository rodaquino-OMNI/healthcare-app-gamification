{
    "name": "@austa/design-system",
    "version": "0.1.0",
    "type": "module",
    "private": true,
    "main": "dist/index.js",
    "module": "dist/index.esm.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.esm.js",
            "require": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "lint": "eslint 'src/**/*.{ts,tsx}'",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:ci": "jest --ci --coverage",
        "typecheck": "tsc --noEmit",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build"
    },
    "dependencies": {
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "styled-components": "6.3.11",
        "react-native-web": "0.21.2",
        "victory-native": "36.9.2",
        "react-native-reanimated": "3.4.0",
        "react-native-gesture-handler": "2.12.0",
        "react-native-svg": "15.15.3",
        "@austa/web-shared": "0.1.0",
        "date-fns": "^4.0.0",
        "recharts": "^2.12.0",
        "react-datepicker": "^9.0.0"
    },
    "devDependencies": {
        "@babel/core": "7.29.0",
        "@babel/preset-env": "7.29.0",
        "@babel/preset-react": "7.28.5",
        "@babel/preset-typescript": "7.28.5",
        "@vitejs/plugin-react": "^4.0.0",
        "@storybook/addon-a11y": "^8.4.0",
        "@storybook/addon-essentials": "^8.4.0",
        "@storybook/addon-interactions": "^8.4.0",
        "@storybook/addon-links": "^8.4.0",
        "@storybook/addon-themes": "^8.4.0",
        "@storybook/react": "^8.4.0",
        "@storybook/react-vite": "^8.4.0",
        "chromatic": "^15.0.0",
        "@testing-library/jest-dom": "5.17.0",
        "@testing-library/react": "14.3.1",
        "@testing-library/react-native": "12.9.0",
        "@types/jest": "29.5.14",
        "@types/react": "18.2.37",
        "@types/react-dom": "18.2.15",
        "@types/styled-components": "5.1.36",
        "@typescript-eslint/eslint-plugin": "5.62.0",
        "@typescript-eslint/parser": "5.62.0",
        "babel-loader": "10.1.1",
        "eslint": "8.43.0",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "4.6.2",
        "eslint-plugin-storybook": "^0.12.0",
        "jest": "29.7.0",
        "jest-environment-jsdom": "29.7.0",
        "jest-styled-components": "7.2.0",
        "lint-staged": "^16.0.0",
        "prettier": "^3.2.5",
        "react-native": "0.73.0",
        "vite-plugin-dts": "^3.0.0",
        "storybook": "^8.4.0",
        "vite": "^5.4.0",
        "typescript": "5.3.3"
    },
    "peerDependencies": {
        "react": ">=18.2.0",
        "react-dom": ">=18.2.0",
        "react-native": "0.73.0",
        "styled-components": ">=6.0.0"
    },
    "engines": {
        "node": ">=16"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.{js,json,css}": [
            "prettier --write"
        ]
    },
    "//overrides": "Child-specific only. 22 redundant entries removed (inherited from workspace root src/web/package.json). Kept: navigation/animation overrides that differ from parent versions.",
    "overrides": {
        "@react-navigation/native": "7.1.8",
        "@react-navigation/stack": "7.3.1",
        "react-native-reanimated": "3.17.5",
        "react-native-gesture-handler": "2.25.0",
        "react-native-safe-area-context": "5.4.0"
    },
    "//resolutions": "DS-specific: react-native 0.72.6 (parent src/web uses 0.73.0). @types/react and @types/react-dom pinned to 18.x for DS devDeps compat. All other CVE/version pins handled by root + src/web parent resolutions.",
    "resolutions": {
        "react-native": "0.72.6",
        "@types/react": "18.2.37",
        "@types/react-dom": "18.2.15"
    }
}
