{
  "name": "austa-superapp-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "src/backend/*",
    "src/web/*"
  ],
  "dependencies": {
    "react-native-web": "^0.20.0"
  },
  "resolutions": {
    "react": "19.0.0",
    "react-dom": "19.0.0",
