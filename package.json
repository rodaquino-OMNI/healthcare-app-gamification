    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "typescript": "5.3.3",
    "rxjs": "7.8.1",
    "graphql": "16.8.1",
    "axios": "1.13.6",
    "follow-redirects": "1.15.11",
    "@babel/traverse": "7.23.2",
    "semver": "7.7.4",
    "react-native-webview": "13.13.5",
    "react-native-agora": "4.5.2",
    "@react-native/typescript-config": "0.73.1",
    "json5": "2.2.3",
    "word-wrap": "1.2.5",
    "tough-cookie": "4.1.4",
    "postcss": "8.5.8",
    "webpack": "5.104.1",
    "node-fetch": "2.7.0",
    "glob-parent": "6.0.2",
    "terser": "5.46.0",
    "loader-utils": "2.0.4",
    "minimist": "1.2.8",
    "shelljs": "0.10.0",
    "qs": "6.15.0",
    "glob": "7.2.3",
    "@babel/plugin-transform-class-properties": "7.23.3",
    "@babel/plugin-transform-nullish-coalescing-operator": "7.23.3",
    "@babel/plugin-transform-optional-chaining": "7.23.3",
    "@babel/plugin-transform-numeric-separator": "7.23.3",
    "@babel/plugin-transform-object-rest-spread": "7.23.3",
    "@babel/plugin-transform-optional-catch-binding": "7.23.3",
    "@babel/plugin-transform-async-generator-functions": "7.23.3",
    "ua-parser-js": "1.0.41",
    "eslint": "8.57.0",
    "@types/react-native": "0.72.2",
    "@react-navigation/native": "6.1.7",
    "@react-navigation/bottom-tabs": "6.5.8",
    "@react-navigation/native-stack": "6.9.13",
    "@react-navigation/stack": "6.3.17",
    "react-native-reanimated": "3.4.0",
    "react-native-gesture-handler": "2.12.0",
    "react-native-safe-area-context": "4.6.3",
    "react-native-screens": "3.22.0",
    "@babel/plugin-transform-unicode-property-regex": "7.23.3",
    "metro": "0.76.8",
    "metro-react-native-babel-preset": "0.76.7",
    "@react-native-community/cli": "11.3.7",
    "minimatch": "3.1.5",
    "ws": "8.19.0",
    "lodash.set": "4.3.2",
    "lodash.get": "4.4.2",
    "cross-fetch": "4.1.0",
    "cookie": "0.7.2",
    "send": "0.19.2",
    "serve-static": "1.16.3",
    "tar": "7.5.11",
    "zod": "3.25.76",
    "js-yaml": "4.1.1",
    "fast-xml-parser": "5.4.2",
    "multer": "2.1.1",
    "body-parser": "1.20.4",
    "serialize-javascript": "7.0.4",
    "path-to-regexp": "8.3.0",
    "immutable": "4.3.8",
    "@nestjs/common": "11.1.16",
    "@nestjs/core": "11.1.16",
    "@nestjs/platform-express": "11.1.16",
    "@prisma/client": "5.22.0",
    "prisma": "5.22.0",
    "fastify": "5.8.2",
    "@fastify/middie": "9.3.1",
    "@remix-run/router": "1.23.2",
    "rollup": "2.80.0",
    "express-rate-limit": "8.3.1",
    "hono": "4.12.7",
    "@hono/node-server": "1.19.11"
  },
  "scripts": {
    "install:all": "yarn install && yarn setup:modules",
    "setup:modules": "node scripts/setup-modules.js",
    "deps:check": "yarn workspaces run outdated",
    "deps:audit": "yarn workspaces run yarn audit",
    "deps:fix-imports": "node scripts/fix-imports.js",
    "deps:validate": "node scripts/validate-package-json.js",
    "deps:fix-common": "node scripts/fix-common-dependencies.js",
    "deps:fix-security": "node scripts/fix-security-vulnerabilities.js",
    "deps:update": "npx npm-check-updates -i",
    "security:check": "yarn audit --groups dependencies",
    "security:report": "node scripts/generate-security-report.js",
    "security:apply-patches": "node scripts/apply-security-patches.js",
    "setup:path-aliases": "node scripts/setup-path-aliases.js",
    "health:check": "node scripts/repo-health-check.js",
    "health:fix": "yarn deps:fix-security && yarn deps:fix-common && yarn setup:path-aliases",
    "build:all": "yarn workspace @austa/shared build && yarn workspaces run build",
    "build:backend": "lerna run build --scope=\"@austa/*\" --ignore=\"@austa/design-system\" --ignore=\"@austa/web-*\"",
    "build:frontend": "turbo run build --filter=\"./src/web/*\"",
    "dev:backend": "lerna run start:dev --parallel --scope=\"@austa/*\" --ignore=\"@austa/design-system\" --ignore=\"@austa/web-*\"",
    "dev:web": "yarn workspace @austa/web dev",
    "dev:mobile": "yarn workspace @austa/mobile start",
    "test:all": "yarn workspaces run test",
    "test:watch": "./node_modules/.bin/jest --watch",
    "test:backend": "./node_modules/.bin/jest --projects src/backend --watch",
    "test:backend:coverage": "./node_modules/.bin/jest --projects src/backend --coverage",
    "verify:types": "yarn workspaces run tsc --noEmit",
    "postinstall": "node ./scripts/apply-security-patches.js || true",
    "deps:fix": "node scripts/fix-dependencies.js"
  },
  "devDependencies": {
    "@ruvector/attention": "^0.1.4",
    "@ruvector/core": "^0.1.30",
    "@ruvector/sona": "^0.1.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.3",
    "@types/react-native": "0.72.2",
    "agentdb": "^2.0.0-alpha.3.3",
    "agentic-flow": "2.0.7",
    "glob": "7.2.3",
    "husky": "^9.0.6",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-watch-typeahead": "^3.0.0",
    "lerna": "^8.0.0",
    "lint-staged": "^15.2.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "turbo": "^2.0.0",
    "typescript": "5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  }
}
