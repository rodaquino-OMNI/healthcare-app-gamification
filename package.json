  "scripts": {
    "prisma:generate": "pnpm --filter @austa/shared exec prisma generate",
    "build": "turbo run build",
    "build:backend": "turbo run build --filter='./src/backend/*'",
    "build:frontend": "turbo run build --filter='./src/web/*'",
    "dev:backend": "turbo run start:dev --filter='./src/backend/*' --parallel",
    "dev:web": "pnpm --filter @austa/web-nextjs dev",
    "dev:mobile": "pnpm --filter austa-mobile start",
    "test": "turbo run test",
    "test:backend": "turbo run test --filter='./src/backend/*'",
    "test:frontend": "turbo run test --filter='./src/web/*'",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "verify:types": "turbo run typecheck",
    "deps:check": "pnpm outdated -r",
    "deps:audit": "pnpm audit",
    "deps:validate": "node scripts/validate-package-json.js",
    "health:check": "node scripts/repo-health-check.js"
  },
  "devDependencies": {
    "@ruvector/attention": "^0.1.4",
    "@ruvector/core": "^0.1.30",
