# ============================================================
# AUSTA Healthcare SuperApp — Environment Variables
# ============================================================
# Copy to .env and fill in values.
# [REQUIRED] = must be set   [OPTIONAL] = has default   [SECRET] = sensitive
# ============================================================

# ---- Core / Common ----
NODE_ENV=development                                # [REQUIRED] development | staging | production | test
PORT=3000                                           # [OPTIONAL] API server port (varies per service)
HOST=0.0.0.0                                        # [OPTIONAL] API server host
API_PREFIX=api                                      # [OPTIONAL] API route prefix
LOG_LEVEL=info                                      # [OPTIONAL] error | warn | info | debug | verbose
LOG_FORMAT=json                                     # [OPTIONAL] json | text | pretty
LOG_DESTINATION=stdout                              # [OPTIONAL] stdout | file
LOG_FILENAME=                                       # [OPTIONAL] Log file path (when LOG_DESTINATION=file)
LOG_FILE_OUTPUT=false                               # [OPTIONAL] Enable file-based logging
LOG_FILE_PATH=./logs/app.log                        # [OPTIONAL] Path to log file
LOG_REQUESTS=true                                   # [OPTIONAL] Log incoming requests
LOG_RESPONSES=true                                  # [OPTIONAL] Log outgoing responses
LOG_PRETTY=false                                    # [OPTIONAL] Pretty-print logs (dev only)
SERVER_TIMEOUT=30000                                # [OPTIONAL] Request timeout in ms

# ---- CORS ----
CORS_ORIGIN=http://localhost:3000                   # [OPTIONAL] Allowed origin (comma-separated or regex)
CORS_ORIGINS=                                       # [OPTIONAL] Comma-separated origins (api-gateway)
CORS_METHODS=GET,POST,PUT,PATCH,DELETE              # [OPTIONAL] Allowed HTTP methods
CORS_CREDENTIALS=true                               # [OPTIONAL] Allow credentials

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/austa   # [REQUIRED][SECRET]
DATABASE_HOST=localhost                             # [OPTIONAL] Used if DATABASE_URL not set
DATABASE_PORT=5432                                  # [OPTIONAL]
DATABASE_NAME=austa                                 # [OPTIONAL]
DATABASE_USERNAME=postgres                          # [OPTIONAL][SECRET]
DATABASE_PASSWORD=                                  # [REQUIRED][SECRET]
DATABASE_TYPE=postgres                              # [OPTIONAL]
DATABASE_SCHEMA=public                              # [OPTIONAL] Schema name
DATABASE_SSL=false                                  # [OPTIONAL] Enable SSL for DB connection
DATABASE_SYNCHRONIZE=false                          # [OPTIONAL] Auto-sync schema (NEVER in prod)
DATABASE_LOGGING=false                              # [OPTIONAL] Enable query logging
DATABASE_MAX_CONNECTIONS=20                         # [OPTIONAL] Max pool connections
DATABASE_POOL_SIZE=10                               # [OPTIONAL] Connection pool size
DATABASE_IDLE_TIMEOUT=30000                         # [OPTIONAL] Idle timeout in ms
DATABASE_QUERY_TIMEOUT=30000                        # [OPTIONAL] Query timeout in ms
RUN_MIGRATIONS=false                                # [OPTIONAL] Auto-run migrations on startup

# ---- Redis ----
REDIS_URL=redis://localhost:6379                    # [REQUIRED][SECRET]
REDIS_HOST=localhost                                # [OPTIONAL] Redis host (if not using URL)
REDIS_PORT=6379                                     # [OPTIONAL] Redis port
REDIS_PASSWORD=                                     # [OPTIONAL][SECRET] Redis password
REDIS_DB=0                                          # [OPTIONAL] Redis database index
REDIS_KEY_PREFIX=austa:                             # [OPTIONAL] Key prefix
REDIS_TTL=3600                                      # [OPTIONAL] Default TTL in seconds
REDIS_TLS=false                                     # [OPTIONAL] Enable TLS for Redis

# ---- Kafka ----
KAFKA_BROKERS=localhost:9092                        # [REQUIRED] Comma-separated broker list
KAFKA_CLIENT_ID=austa-app                           # [OPTIONAL] Kafka client ID
KAFKA_GROUP_ID=austa-consumer-group                 # [OPTIONAL] Consumer group ID
KAFKA_SSL=false                                     # [OPTIONAL] Enable SSL for Kafka
KAFKA_MAX_RETRIES=3                                 # [OPTIONAL] Max retry attempts
KAFKA_RETRY_INTERVAL=1000                           # [OPTIONAL] Retry interval in ms

# Kafka topics
KAFKA_TOPIC_HEALTH_EVENTS=health.events             # [OPTIONAL] Health journey events topic
KAFKA_TOPIC_CARE_EVENTS=care.events                 # [OPTIONAL] Care journey events topic
KAFKA_TOPIC_PLAN_EVENTS=plan.events                 # [OPTIONAL] Plan journey events topic
KAFKA_TOPIC_USER_EVENTS=user.events                 # [OPTIONAL] User events topic
KAFKA_TOPIC_GAME_EVENTS=game.events                 # [OPTIONAL] Gamification events topic
HEALTH_EVENTS_TOPIC=health.events                   # [OPTIONAL] Alias for health events
CARE_EVENTS_TOPIC=care.events                       # [OPTIONAL] Alias for care events
PLAN_EVENTS_TOPIC=plan.events                       # [OPTIONAL] Alias for plan events
USER_EVENTS_TOPIC=user.events                       # [OPTIONAL] Alias for user events
GAME_EVENTS_TOPIC=game.events                       # [OPTIONAL] Alias for game events
EVENTS_KAFKA_ENABLED=false                          # [OPTIONAL] Enable Kafka event streaming
EVENTS_KAFKA_BROKERS=localhost:9092                  # [OPTIONAL] Event-specific broker list
EVENTS_TOPIC_PREFIX=austa.health                    # [OPTIONAL] Topic prefix for events

# ---- S3 / Storage ----
STORAGE_PROVIDER=s3                                 # [OPTIONAL] s3 | local
S3_BUCKET=                                          # [REQUIRED][SECRET] S3 bucket name
S3_REGION=sa-east-1                                 # [OPTIONAL] AWS region
S3_ACCESS_KEY_ID=                                   # [REQUIRED][SECRET] AWS access key
S3_SECRET_ACCESS_KEY=                               # [REQUIRED][SECRET] AWS secret key
S3_ENDPOINT=                                        # [OPTIONAL] Custom S3 endpoint (MinIO, etc.)
S3_PATH_PREFIX=plan                                 # [OPTIONAL] Path prefix in bucket
STORAGE_S3_BUCKET=                                  # [OPTIONAL] Health service S3 bucket
STORAGE_S3_REGION=sa-east-1                         # [OPTIONAL] Health service S3 region
STORAGE_S3_PREFIX=health                            # [OPTIONAL] Health service S3 prefix
LOCAL_STORAGE_DIRECTORY=                             # [OPTIONAL] Local storage dir (when provider=local)

# ---- Auth Service ----
AUTH_SERVICE_PORT=3001                              # [OPTIONAL] Auth service port
AUTH_SERVICE_API_PREFIX=api/v1                      # [OPTIONAL] Auth service API prefix
AUTH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth  # [OPTIONAL][SECRET]

# JWT
JWT_SECRET=                                         # [REQUIRED][SECRET] JWT signing secret (min 32 chars)
JWT_ACCESS_EXPIRATION=1h                            # [OPTIONAL] Access token TTL
JWT_REFRESH_EXPIRATION=7d                           # [OPTIONAL] Refresh token TTL
JWT_ISSUER=austa.com.br                             # [OPTIONAL] Token issuer
JWT_AUDIENCE=austa-users                            # [OPTIONAL] Token audience
AUTH_JWT_SECRET=                                    # [REQUIRED][SECRET] Auth service JWT secret
AUTH_JWT_EXPIRATION=1h                              # [OPTIONAL]
AUTH_REFRESH_TOKEN_EXPIRATION=7d                    # [OPTIONAL]
AUTH_REFRESH_TOKEN_SECRET=                          # [REQUIRED][SECRET]
TOKEN_EXPIRATION=1h                                 # [OPTIONAL] API gateway token TTL
REFRESH_TOKEN_EXPIRATION=7d                         # [OPTIONAL] API gateway refresh TTL
TOKEN_ISSUER=austa.com.br                           # [OPTIONAL]
TOKEN_AUDIENCE=austa-users                          # [OPTIONAL]
JWT_EXPIRATION=3600                                 # [OPTIONAL] Gamification JWT TTL in seconds

# OAuth Providers
GOOGLE_CLIENT_ID=                                   # [OPTIONAL][SECRET] Google OAuth client ID
GOOGLE_CLIENT_SECRET=                               # [OPTIONAL][SECRET] Google OAuth client secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback  # [OPTIONAL]
GOOGLE_AUTH_ENABLED=false                           # [OPTIONAL]
FACEBOOK_CLIENT_ID=                                 # [OPTIONAL][SECRET]
FACEBOOK_CLIENT_SECRET=                             # [OPTIONAL][SECRET]
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/v1/auth/facebook/callback  # [OPTIONAL]
FACEBOOK_AUTH_ENABLED=false                         # [OPTIONAL]
APPLE_CLIENT_ID=                                    # [OPTIONAL][SECRET]
APPLE_TEAM_ID=                                      # [OPTIONAL][SECRET]
APPLE_KEY_ID=                                       # [OPTIONAL][SECRET]
APPLE_PRIVATE_KEY=                                  # [OPTIONAL][SECRET]
APPLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/apple/callback  # [OPTIONAL]
APPLE_AUTH_ENABLED=false                            # [OPTIONAL]
OAUTH_GOOGLE_CLIENT_ID=                             # [OPTIONAL][SECRET] Validation schema alias
OAUTH_GOOGLE_CLIENT_SECRET=                         # [OPTIONAL][SECRET]
OAUTH_FACEBOOK_CLIENT_ID=                           # [OPTIONAL][SECRET]
OAUTH_FACEBOOK_CLIENT_SECRET=                       # [OPTIONAL][SECRET]
OAUTH_APPLE_CLIENT_ID=                              # [OPTIONAL][SECRET]
OAUTH_APPLE_CLIENT_SECRET=                          # [OPTIONAL][SECRET]
OAUTH_REDIRECT_URL=                                 # [OPTIONAL]

# MFA
MFA_ENABLED=true                                    # [OPTIONAL] Enable multi-factor auth
MFA_ISSUER=AUSTA SuperApp                           # [OPTIONAL] MFA issuer name
MFA_CODE_EXPIRATION=300                             # [OPTIONAL] MFA code TTL in seconds
MFA_EXPIRY_SECONDS=300                              # [OPTIONAL] Alias for code expiration
MFA_WINDOW_SIZE=1                                   # [OPTIONAL] TOTP time steps to check
SMS_PROVIDER=twilio                                 # [OPTIONAL] twilio | sns | custom
MFA_SMS_PROVIDER=twilio                             # [OPTIONAL] Alias
MFA_SMS_PROVIDER_API_KEY=                           # [REQUIRED][SECRET] SMS provider API key
EMAIL_MFA_ENABLED=false                             # [OPTIONAL] Enable email MFA
SMS_MFA_ENABLED=false                               # [OPTIONAL] Enable SMS MFA
TOTP_MFA_ENABLED=false                              # [OPTIONAL] Enable TOTP MFA

# Biometric Authentication
BIOMETRIC_AUTHENTICATION_ENABLED=true               # [OPTIONAL]
BIOMETRIC_DEVICE_KEY_EXPIRATION_DAYS=90             # [OPTIONAL]

# Password Policy
PASSWORD_MIN_LENGTH=10                              # [OPTIONAL]
PASSWORD_REQUIRE_UPPERCASE=true                     # [OPTIONAL]
PASSWORD_REQUIRE_LOWERCASE=true                     # [OPTIONAL]
PASSWORD_REQUIRE_NUMBER=true                        # [OPTIONAL]
PASSWORD_REQUIRE_SPECIAL=true                       # [OPTIONAL]
PASSWORD_REQUIRE_SYMBOL=true                        # [OPTIONAL] Alias
PASSWORD_HISTORY=5                                  # [OPTIONAL] Remember last N passwords
PASSWORD_HISTORY_COUNT=5                            # [OPTIONAL] Alias
PASSWORD_MAX_AGE=7776000                            # [OPTIONAL] Max age in seconds (90 days)
PASSWORD_MAX_AGE_DAYS=90                            # [OPTIONAL] Max age in days
PASSWORD_LOCKOUT_THRESHOLD=5                        # [OPTIONAL] Failed attempts before lockout
PASSWORD_LOCKOUT_DURATION=1800                      # [OPTIONAL] Lockout duration in seconds
REQUIRE_STRONG_PASSWORD=true                        # [OPTIONAL]

# Account Lockout
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5                      # [OPTIONAL]
ACCOUNT_LOCKOUT_DURATION_MINUTES=30                 # [OPTIONAL]
ACCOUNT_LOCKOUT_RESET_ATTEMPTS_AFTER_MINUTES=15     # [OPTIONAL]

# Session Management
MAX_CONCURRENT_SESSIONS=5                           # [OPTIONAL]
SESSION_ABSOLUTE_TIMEOUT=43200                      # [OPTIONAL] In seconds (12 hours)
SESSION_ABSOLUTE_TIMEOUT_HOURS=12                   # [OPTIONAL] Alias in hours
SESSION_INACTIVITY_TIMEOUT=1800                     # [OPTIONAL] In seconds (30 min)
SESSION_IDLE_TIMEOUT_MINUTES=30                     # [OPTIONAL] Alias in minutes
SESSION_MAX_CONCURRENT=5                            # [OPTIONAL] Alias
REMEMBER_ME_EXTENSION=2592000                       # [OPTIONAL] In seconds (30 days)

# Email Verification
REQUIRE_EMAIL_VERIFICATION=true                     # [OPTIONAL]
EMAIL_VERIFICATION_EXPIRY_HOURS=24                  # [OPTIONAL]

# ---- Care Service ----
CARE_SERVICE_PORT=3002                              # [OPTIONAL]
CARE_SERVICE_API_PREFIX=api/v1                      # [OPTIONAL]
CARE_SERVICE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/austa_care  # [OPTIONAL][SECRET]
CARE_SERVICE_DB_MAX_CONNECTIONS=10                  # [OPTIONAL]
CARE_SERVICE_DB_IDLE_TIMEOUT=30000                  # [OPTIONAL]
CARE_SERVICE_DB_SSL=false                           # [OPTIONAL]

# Care Service Redis
CARE_SERVICE_REDIS_URL=redis://localhost:6379        # [OPTIONAL]
CARE_SERVICE_REDIS_TTL=3600                         # [OPTIONAL]
CARE_SERVICE_REDIS_PREFIX=care:                     # [OPTIONAL]

# Care Service Auth
CARE_SERVICE_JWT_SECRET=                            # [OPTIONAL][SECRET]
CARE_SERVICE_JWT_EXPIRES=1h                         # [OPTIONAL]
CARE_SERVICE_OAUTH_AUTHORITY=https://auth.austa.com.br  # [OPTIONAL]
CARE_SERVICE_OAUTH_CLIENT_ID=care-service           # [OPTIONAL]
CARE_SERVICE_OAUTH_CLIENT_SECRET=                   # [OPTIONAL][SECRET]
CARE_SERVICE_OAUTH_AUDIENCE=api://care-service      # [OPTIONAL]

# Provider Systems
CARE_SERVICE_PROVIDERS_API_URL=https://providers-api.austa.com.br  # [OPTIONAL]
CARE_SERVICE_PROVIDERS_API_KEY=                     # [OPTIONAL][SECRET]
CARE_SERVICE_PROVIDERS_TIMEOUT=5000                 # [OPTIONAL]
CARE_SERVICE_PROVIDERS_CACHE_ENABLED=false          # [OPTIONAL]
CARE_SERVICE_PROVIDERS_CACHE_TTL=300                # [OPTIONAL]
CARE_SERVICE_PROVIDERS_RETRY_ATTEMPTS=3             # [OPTIONAL]
CARE_SERVICE_PROVIDERS_RETRY_DELAY=1000             # [OPTIONAL]

# Appointments
CARE_SERVICE_MAX_ADVANCE_DAYS=90                    # [OPTIONAL] Max days to book ahead
CARE_SERVICE_APPOINTMENT_REMINDER_SCHEDULE=24h,1h   # [OPTIONAL]
CARE_SERVICE_DEFAULT_APPOINTMENT_DURATION=30        # [OPTIONAL] Minutes
CARE_SERVICE_CANCELLATION_POLICY_ENABLED=true       # [OPTIONAL]
CARE_SERVICE_MIN_CANCELLATION_HOURS=24              # [OPTIONAL]
CARE_SERVICE_CANCELLATION_XP_LOSS=50                # [OPTIONAL]
CARE_SERVICE_AVAILABILITY_BUFFER=15                 # [OPTIONAL] Minutes between appointments

# Telemedicine (Agora)
CARE_SERVICE_TELEMEDICINE_ENABLED=true              # [OPTIONAL]
CARE_SERVICE_TELEMEDICINE_PROVIDER=agora            # [OPTIONAL]
CARE_SERVICE_AGORA_APP_ID=                          # [REQUIRED][SECRET] Agora App ID
CARE_SERVICE_AGORA_APP_CERTIFICATE=                 # [REQUIRED][SECRET] Agora App Certificate
CARE_SERVICE_AGORA_TOKEN_EXPIRATION=3600            # [OPTIONAL] Token TTL in seconds
CARE_SERVICE_TELEMEDICINE_RECORDING=false            # [OPTIONAL]
CARE_SERVICE_TELEMEDICINE_RECORDING_BUCKET=austa-telemedicine-recordings  # [OPTIONAL]
CARE_SERVICE_TELEMEDICINE_RECORDING_REGION=sa-east-1  # [OPTIONAL]
CARE_SERVICE_RECORDING_RETENTION_DAYS=90            # [OPTIONAL]
CARE_SERVICE_TELEMEDICINE_MIN_BITRATE=350000        # [OPTIONAL]
CARE_SERVICE_TELEMEDICINE_MIN_FRAMERATE=15          # [OPTIONAL]
CARE_SERVICE_TELEMEDICINE_CONNECTION_TIMEOUT=30000  # [OPTIONAL]
CARE_SERVICE_TELEMEDICINE_DEFAULT_DURATION=20       # [OPTIONAL] Minutes
CARE_SERVICE_TELEMEDICINE_MAX_DURATION=60           # [OPTIONAL] Minutes
CARE_SERVICE_TELEMEDICINE_WARNING_TIME=5            # [OPTIONAL] Warning N min before end
TELEMEDICINE_API_KEY=                               # [REQUIRED][SECRET] Telemedicine API key
TELEMEDICINE_API_URL=                               # [REQUIRED] Telemedicine API URL

# Symptom Checker
CARE_SERVICE_SYMPTOMS_CHECKER_ENABLED=true          # [OPTIONAL]
CARE_SERVICE_SYMPTOMS_CHECKER_PROVIDER=internal     # [OPTIONAL] internal | external
CARE_SERVICE_SYMPTOMS_CHECKER_API_URL=https://symptoms-api.austa.com.br  # [OPTIONAL]
CARE_SERVICE_SYMPTOMS_CHECKER_API_KEY=              # [OPTIONAL][SECRET]
CARE_SERVICE_SYMPTOMS_CHECKER_TIMEOUT=10000         # [OPTIONAL]
CARE_SERVICE_EMERGENCY_SYMPTOMS=chest_pain,difficulty_breathing,severe_bleeding  # [OPTIONAL]
CARE_SERVICE_SYMPTOMS_UPDATE_FREQUENCY=weekly       # [OPTIONAL]
SYMPTOM_CHECKER_API_TIMEOUT=5000                    # [OPTIONAL]

# Medication Tracking
CARE_SERVICE_MEDICATION_REMINDERS=true              # [OPTIONAL]
CARE_SERVICE_MEDICATION_DEFAULT_REMINDER_TIME=1h,0h  # [OPTIONAL]
CARE_SERVICE_MEDICATION_ADHERENCE_THRESHOLD=0.8     # [OPTIONAL]
CARE_SERVICE_REFILL_REMINDER_DAYS=7                 # [OPTIONAL]
CARE_SERVICE_MAX_MISSED_DOSES=3                     # [OPTIONAL]
CARE_SERVICE_DOSE_WINDOW_MINUTES=60                 # [OPTIONAL]
MEDICATION_API_TIMEOUT=5000                         # [OPTIONAL]

# Treatment Plans
CARE_SERVICE_TREATMENT_REMINDERS=true               # [OPTIONAL]
CARE_SERVICE_TREATMENT_PROGRESS_FREQUENCY=daily     # [OPTIONAL]
CARE_SERVICE_TREATMENT_AT_RISK_THRESHOLD=0.6        # [OPTIONAL]
CARE_SERVICE_TREATMENT_ON_TRACK_THRESHOLD=0.8       # [OPTIONAL]
CARE_SERVICE_TREATMENT_MISSED_ACTIVITIES=3          # [OPTIONAL]
CARE_SERVICE_TREATMENT_MISSED_APPOINTMENTS=1        # [OPTIONAL]
TREATMENT_API_TIMEOUT=5000                          # [OPTIONAL]

# Care Notifications
CARE_SERVICE_NOTIFICATIONS_URL=http://notification-service:3006  # [OPTIONAL]
CARE_SERVICE_NOTIFICATIONS_API_KEY=                 # [OPTIONAL][SECRET]
CARE_SERVICE_DEFAULT_NOTIFICATION_CHANNEL=push,email  # [OPTIONAL]
CARE_SERVICE_NOTIFICATION_THROTTLING=true           # [OPTIONAL]
CARE_SERVICE_MAX_NOTIFICATIONS_HOUR=5               # [OPTIONAL]
CARE_SERVICE_MAX_NOTIFICATIONS_DAY=20               # [OPTIONAL]
CARE_SERVICE_APPOINTMENT_REMINDER_TEMPLATE=care-appointment-reminder  # [OPTIONAL]
CARE_SERVICE_APPOINTMENT_CONFIRMATION_TEMPLATE=care-appointment-confirmation  # [OPTIONAL]
CARE_SERVICE_MEDICATION_REMINDER_TEMPLATE=care-medication-reminder  # [OPTIONAL]
CARE_SERVICE_TREATMENT_UPDATE_TEMPLATE=care-treatment-update  # [OPTIONAL]
NOTIFICATIONS_SERVICE_URL=                          # [OPTIONAL] Notifications service URL
NOTIFICATIONS_SERVICE_TIMEOUT=5000                  # [OPTIONAL]

# Care Gamification
CARE_SERVICE_GAMIFICATION_ENABLED=true              # [OPTIONAL]
CARE_SERVICE_GAMIFICATION_URL=http://gamification-service:3005  # [OPTIONAL]
CARE_SERVICE_GAMIFICATION_API_KEY=                  # [OPTIONAL][SECRET]
CARE_SERVICE_POINTS_APPOINTMENT_BOOKED=10           # [OPTIONAL]
CARE_SERVICE_POINTS_APPOINTMENT_ATTENDED=50         # [OPTIONAL]
CARE_SERVICE_POINTS_TELEMEDICINE_COMPLETED=50       # [OPTIONAL]
CARE_SERVICE_POINTS_MEDICATION_PERFECT_WEEK=100     # [OPTIONAL]
CARE_SERVICE_POINTS_TREATMENT_MILESTONE=75          # [OPTIONAL]

# Care API Timeouts
APPOINTMENT_API_TIMEOUT=5000                        # [OPTIONAL]
PROVIDER_API_TIMEOUT=5000                           # [OPTIONAL]
TELEMEDICINE_API_TIMEOUT=5000                       # [OPTIONAL]

# Pharmacy Integration
CARE_SERVICE_PHARMACY_INTEGRATION=false             # [OPTIONAL]
CARE_SERVICE_PHARMACY_API_URL=https://pharmacy-api.austa.com.br  # [OPTIONAL]
CARE_SERVICE_PHARMACY_API_KEY=                      # [OPTIONAL][SECRET]
CARE_SERVICE_PHARMACY_TIMEOUT=5000                  # [OPTIONAL]
CARE_SERVICE_PHARMACY_CACHE_ENABLED=true            # [OPTIONAL]
CARE_SERVICE_PHARMACY_CACHE_TTL=3600                # [OPTIONAL]

# Emergency Services
CARE_SERVICE_EMERGENCY_INTEGRATION=false            # [OPTIONAL]
CARE_SERVICE_EMERGENCY_API_URL=https://emergency-api.austa.com.br  # [OPTIONAL]
CARE_SERVICE_EMERGENCY_API_KEY=                     # [OPTIONAL][SECRET]
CARE_SERVICE_EMERGENCY_NUMBER=192                   # [OPTIONAL] Brazil emergency number

# Care Feature Flags
CARE_SERVICE_ENABLE_SYMPTOMS_CHECKER=true           # [OPTIONAL]
CARE_SERVICE_ENABLE_TREATMENT_TRACKING=true         # [OPTIONAL]
CARE_SERVICE_ENABLE_EMERGENCY_ACCESS=false          # [OPTIONAL]
CARE_SERVICE_ENABLE_VIRTUAL_WAITING_ROOM=false      # [OPTIONAL]
CARE_SERVICE_ENABLE_PROVIDER_RATINGS=true           # [OPTIONAL]
CARE_SERVICE_ENABLE_DOCUMENT_SHARING=true           # [OPTIONAL]
CARE_SERVICE_ENABLE_FOLLOW_UP_SUGGESTIONS=true      # [OPTIONAL]

# Care Logging
CARE_SERVICE_LOG_LEVEL=info                         # [OPTIONAL]
CARE_SERVICE_LOG_FORMAT=json                        # [OPTIONAL]
CARE_SERVICE_REQUEST_LOGGING=true                   # [OPTIONAL]
CARE_SERVICE_SENSITIVE_DATA_FIELDS=password,token,healthData  # [OPTIONAL]

# ---- Health Service ----
# TimescaleDB
TIMESCALE_ENABLED=false                             # [OPTIONAL] Enable TimescaleDB extension
METRICS_RETENTION_DAYS=730                          # [OPTIONAL] Metrics retention (2 years)
METRICS_AGGREGATION_ENABLED=false                   # [OPTIONAL] Enable metrics aggregation
METRICS_AGGREGATION_INTERVALS=hour,day,week,month   # [OPTIONAL] Aggregation intervals

# FHIR API
FHIR_API_ENABLED=false                              # [OPTIONAL] Enable FHIR integration
FHIR_API_URL=                                       # [REQUIRED if FHIR enabled] FHIR server URL
FHIR_API_AUTH_TYPE=oauth2                           # [OPTIONAL] oauth2 | basic | none
FHIR_API_CLIENT_ID=                                 # [REQUIRED if FHIR oauth2][SECRET]
FHIR_API_CLIENT_SECRET=                             # [REQUIRED if FHIR oauth2][SECRET]
FHIR_API_SCOPE=                                     # [OPTIONAL] OAuth2 scope
FHIR_API_TOKEN_URL=                                 # [REQUIRED if FHIR oauth2]
FHIR_API_USERNAME=                                  # [REQUIRED if FHIR basic][SECRET]
FHIR_API_PASSWORD=                                  # [REQUIRED if FHIR basic][SECRET]
FHIR_API_TIMEOUT=10000                              # [OPTIONAL] Timeout in ms

# Wearables Integration
WEARABLES_SYNC_ENABLED=false                        # [OPTIONAL] Enable wearable sync
WEARABLES_SUPPORTED=googlefit,healthkit,fitbit      # [OPTIONAL] Supported platforms
WEARABLES_SYNC_INTERVAL=15                          # [OPTIONAL] Sync interval in minutes
WEARABLES_MAX_SYNC_DAYS=30                          # [OPTIONAL] Max days to sync

# Google Fit
GOOGLEFIT_CLIENT_ID=                                # [REQUIRED if wearables enabled][SECRET]
GOOGLEFIT_CLIENT_SECRET=                            # [REQUIRED if wearables enabled][SECRET]

# Apple HealthKit
HEALTHKIT_TEAM_ID=                                  # [REQUIRED if wearables enabled][SECRET]
HEALTHKIT_KEY_ID=                                   # [REQUIRED if wearables enabled][SECRET]
HEALTHKIT_PRIVATE_KEY=                              # [REQUIRED if wearables enabled][SECRET]

# Fitbit
FITBIT_CLIENT_ID=                                   # [REQUIRED if wearables enabled][SECRET]
FITBIT_CLIENT_SECRET=                               # [REQUIRED if wearables enabled][SECRET]

# Health Goals & Insights
HEALTH_GOALS_MAX_ACTIVE=10                          # [OPTIONAL] Max active goals per user
HEALTH_INSIGHTS_ENABLED=false                       # [OPTIONAL] Enable AI health insights
HEALTH_INSIGHTS_GENERATION_INTERVAL=24              # [OPTIONAL] Generation interval in hours
HEALTH_INSIGHTS_MODELS_PATH=                        # [REQUIRED if insights enabled] Path to ML models

# Medical History
MEDICAL_HISTORY_MAX_EVENTS=1000                     # [OPTIONAL] Max events per patient

# ---- Plan Service ----
# Insurance API
INSURANCE_API_BASE_URL=                             # [REQUIRED] Insurance provider API base URL
INSURANCE_API_KEY=                                  # [REQUIRED][SECRET] Insurance API key
INSURANCE_API_TIMEOUT=10000                         # [OPTIONAL] Timeout in ms
INSURANCE_API_RETRIES=3                             # [OPTIONAL] Max retries
INSURANCE_API_RATE_LIMIT_WINDOW=60000               # [OPTIONAL] Rate limit window in ms
INSURANCE_API_RATE_LIMIT_MAX=100                    # [OPTIONAL] Max requests per window

# Claims Processing
CLAIMS_SUPPORTED_DOC_TYPES=pdf,jpg,jpeg,png         # [OPTIONAL] Supported document types
CLAIMS_MAX_DOC_SIZE=10485760                        # [OPTIONAL] Max doc size in bytes (10MB)
CLAIMS_MAX_DOCS_PER_CLAIM=5                         # [OPTIONAL]
CLAIMS_AUTO_APPROVAL_THRESHOLD=100                  # [OPTIONAL] Auto-approve below this amount (BRL)
CLAIMS_PROCESSING_TIME_STANDARD=3                   # [OPTIONAL] Standard processing days
CLAIMS_PROCESSING_TIME_EXPRESS=1                    # [OPTIONAL] Express processing days
CLAIMS_RETENTION_PERIOD=2555                        # [OPTIONAL] Retention period in days (7 years)

# Cost Simulator
COST_SIMULATOR_CURRENCY=BRL                         # [OPTIONAL]
PROCEDURE_CATALOG_SOURCE=database                   # [OPTIONAL] database | api
PROCEDURE_CATALOG_API_ENDPOINT=                     # [REQUIRED if source=api]
PROCEDURE_CATALOG_REFRESH_INTERVAL=86400            # [OPTIONAL] Refresh interval in seconds (24h)
COVERAGE_DEFAULT_CONSULTATIONS=80                   # [OPTIONAL] Default coverage %
COVERAGE_DEFAULT_EXAMINATIONS=70                    # [OPTIONAL]
COVERAGE_DEFAULT_PROCEDURES=60                      # [OPTIONAL]
COVERAGE_DEFAULT_EMERGENCIES=90                     # [OPTIONAL]

# Plan Gamification
GAMIFICATION_ENABLED=true                           # [OPTIONAL]
GAMIFICATION_EVENT_ENDPOINT=                        # [REQUIRED] Gamification event endpoint
GAMIFICATION_TIMEOUT=5000                           # [OPTIONAL]
GAMIFICATION_EVENT_CLAIM_SUBMITTED=CLAIM_SUBMITTED  # [OPTIONAL]
GAMIFICATION_EVENT_CLAIM_APPROVED=CLAIM_APPROVED    # [OPTIONAL]
GAMIFICATION_EVENT_DIGITAL_CARD_ACCESSED=DIGITAL_CARD_ACCESSED  # [OPTIONAL]
GAMIFICATION_EVENT_BENEFIT_USED=BENEFIT_USED        # [OPTIONAL]

# Plan Notifications
NOTIFICATIONS_ENABLED=true                          # [OPTIONAL]
NOTIFICATIONS_SERVICE_ENDPOINT=                     # [REQUIRED] Notification service endpoint
NOTIFICATIONS_TIMEOUT=5000                          # [OPTIONAL]
NOTIFICATIONS_TEMPLATE_CLAIM_STATUS=plan-claim-status      # [OPTIONAL]
NOTIFICATIONS_TEMPLATE_CLAIM_REMINDER=plan-claim-reminder  # [OPTIONAL]
NOTIFICATIONS_TEMPLATE_BENEFIT_EXPIRATION=plan-benefit-expiration  # [OPTIONAL]

# ---- Gamification Engine ----
# Points Configuration
DEFAULT_POINT_HEALTH_METRIC_RECORDED=10             # [OPTIONAL]
DEFAULT_POINT_APPOINTMENT_BOOKED=20                 # [OPTIONAL]
DEFAULT_POINT_APPOINTMENT_ATTENDED=50               # [OPTIONAL]
DEFAULT_POINT_CLAIM_SUBMITTED=15                    # [OPTIONAL]
DEFAULT_POINT_GOAL_COMPLETED=100                    # [OPTIONAL]
MAX_POINTS_PER_DAY=1000                             # [OPTIONAL]
MAX_POINTS_PER_ACTION=500                           # [OPTIONAL]
DEFAULT_POINTS_EXPIRY_DAYS=365                      # [OPTIONAL] Points expiration in days

# Event Processing
EVENT_PROCESSING_RATE=1000                          # [OPTIONAL] Events per second
EVENT_BATCH_SIZE=100                                # [OPTIONAL] Batch size for processing
RULES_REFRESH_INTERVAL=60000                        # [OPTIONAL] Rules refresh in ms
EVENT_PROCESSOR_CONCURRENCY=10                      # [OPTIONAL] Concurrent processing workers
RULE_EVALUATION_TIMEOUT_MS=5000                     # [OPTIONAL] Rule eval timeout
MAX_EVENT_QUEUE_SIZE=10000                          # [OPTIONAL] Max event queue size

# Leaderboard
ENABLE_LEADERBOARDS=true                            # [OPTIONAL]
LEADERBOARD_UPDATE_INTERVAL=900000                  # [OPTIONAL] Update interval in ms (15 min)
LEADERBOARD_UPDATE_INTERVAL_MS=60000                # [OPTIONAL] Alias
LEADERBOARD_MAX_ENTRIES=100                         # [OPTIONAL]

# Achievements
ACHIEVEMENT_NOTIFICATION_ENABLED=true               # [OPTIONAL]
ACHIEVEMENTS_NOTIFICATIONS_ENABLED=true             # [OPTIONAL]
ACHIEVEMENTS_PROGRESS_TRACKING_ENABLED=true         # [OPTIONAL]
ACHIEVEMENTS_MAX_CONCURRENT_QUESTS=5                # [OPTIONAL]
ACHIEVEMENT_RULES_PATH=./config/rules               # [OPTIONAL]
MAX_ACHIEVEMENTS_PER_USER=1000                      # [OPTIONAL]
POINTS_PRECISION=2                                  # [OPTIONAL] Decimal places

# Rewards
REWARDS_EXPIRATION_DAYS=30                          # [OPTIONAL]
REWARDS_REDEMPTION_ENABLED=true                     # [OPTIONAL]

# Cache TTLs (Gamification)
ACHIEVEMENTS_TTL=3600                               # [OPTIONAL] Achievement cache TTL in seconds
USER_PROFILE_TTL=300                                # [OPTIONAL] User profile cache TTL
LEADERBOARD_TTL=900                                 # [OPTIONAL] Leaderboard cache TTL
RULES_TTL=600                                       # [OPTIONAL] Rules cache TTL
CACHE_ENABLED=true                                  # [OPTIONAL] Enable caching
CACHE_TTL=300                                       # [OPTIONAL] Default cache TTL in seconds

# Journey Toggles
HEALTH_JOURNEY_ENABLED=true                         # [OPTIONAL]
CARE_JOURNEY_ENABLED=true                           # [OPTIONAL]
PLAN_JOURNEY_ENABLED=true                           # [OPTIONAL]

# Anti-Cheat
ANTI_CHEAT_ENABLED=true                             # [OPTIONAL]
MAX_EVENTS_PER_USER_PER_MINUTE=100                  # [OPTIONAL]

# Feature Flags (Gamification)
ENABLE_QUESTS=true                                  # [OPTIONAL]
ENABLE_REWARDS=true                                 # [OPTIONAL]
ENABLE_LEVELS=true                                  # [OPTIONAL]

# Maintenance
MAINTENANCE_MODE=false                              # [OPTIONAL]
MAINTENANCE_MESSAGE=Gamification system under maintenance  # [OPTIONAL]

# ---- Notification Service ----
NOTIFICATION_PORT=3003                              # [OPTIONAL]
WEBSOCKET_PORT=3004                                 # [OPTIONAL] WebSocket port
EMAIL_PROVIDER=                                     # [REQUIRED] Email provider name
EMAIL_API_KEY=                                      # [REQUIRED][SECRET] Email provider API key
EMAIL_DEFAULT_FROM=                                 # [REQUIRED] Default sender email
EMAIL_FROM_ADDRESS=notifications@austa.com          # [OPTIONAL] Sender address
EMAIL_FROM_NAME=AUSTA Notifications                 # [OPTIONAL] Sender display name
SMS_ACCOUNT_SID=                                    # [REQUIRED][SECRET] SMS account SID (Twilio)
SMS_AUTH_TOKEN=                                     # [REQUIRED][SECRET] SMS auth token
SMS_DEFAULT_FROM=                                   # [REQUIRED] Default SMS sender number
SMS_FROM_NUMBER=+123456789                          # [OPTIONAL] SMS sender number
PUSH_API_KEY=                                       # [REQUIRED][SECRET] Push notification API key (Firebase)
FIREBASE_API_KEY=                                   # [OPTIONAL][SECRET] Firebase API key alias
PUSH_ENABLED=true                                   # [OPTIONAL]
EMAIL_ENABLED=true                                  # [OPTIONAL]
SMS_ENABLED=true                                    # [OPTIONAL]
INAPP_ENABLED=true                                  # [OPTIONAL]
CHANNEL_PRIORITY=push,email,sms,in-app              # [OPTIONAL] Notification channel priority
DEFAULT_JOURNEY=default                             # [OPTIONAL]
MAX_RETRIES=3                                       # [OPTIONAL] Max delivery retries
RETRY_DELAY=1000                                    # [OPTIONAL] Retry delay in ms
EXPIRATION_TIME=86400                               # [OPTIONAL] Notification expiry in seconds (24h)

# ---- API Gateway ----
API_BASE_URL=http://localhost:4000                   # [OPTIONAL] API Gateway base URL

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000                         # [OPTIONAL] Rate limit window (15 min)
RATE_LIMIT_MAX=100                                  # [OPTIONAL] Max requests per window
RATE_LIMIT_ENABLED=true                             # [OPTIONAL]
RATE_LIMIT_MAX_REQUESTS=1000                        # [OPTIONAL] Gamification rate limit
RATE_LIMIT_HEALTH=200                               # [OPTIONAL] Health journey rate limit
RATE_LIMIT_CARE=150                                 # [OPTIONAL] Care journey rate limit
RATE_LIMIT_PLAN=100                                 # [OPTIONAL] Plan journey rate limit
RATE_LIMIT_LOGIN_MAX=10                             # [OPTIONAL] Login rate limit
RATE_LIMIT_LOGIN_WINDOW_MINUTES=5                   # [OPTIONAL]
RATE_LIMIT_REGISTER_MAX=5                           # [OPTIONAL]
RATE_LIMIT_REGISTER_WINDOW_MINUTES=60               # [OPTIONAL]
RATE_LIMIT_FORGOT_PASSWORD_MAX=5                    # [OPTIONAL]
RATE_LIMIT_FORGOT_PASSWORD_WINDOW_MINUTES=60        # [OPTIONAL]
RATE_LIMIT_DEFAULT=100                              # [OPTIONAL] Notification rate limit

# Cache (Gateway)
CACHE_TTL_HEALTH=5m                                 # [OPTIONAL] Health journey cache TTL
CACHE_TTL_CARE=1m                                   # [OPTIONAL] Care journey cache TTL
CACHE_TTL_PLAN=15m                                  # [OPTIONAL] Plan journey cache TTL
CACHE_TTL_DEFAULT=5m                                # [OPTIONAL] Default cache TTL

# GraphQL
GRAPHQL_PLAYGROUND=false                            # [OPTIONAL] Enable GraphQL playground
GRAPHQL_DEBUG=false                                 # [OPTIONAL] Enable GraphQL debug mode
GRAPHQL_SCHEMA_FILE=schema.gql                      # [OPTIONAL] Schema output file

# Backend Service URLs (from API Gateway)
AUTH_SERVICE_URL=http://auth-service:3000            # [OPTIONAL]
AUTH_SERVICE_TIMEOUT=5000                           # [OPTIONAL]
HEALTH_SERVICE_URL=http://health-service:3000       # [OPTIONAL]
HEALTH_SERVICE_TIMEOUT=5000                         # [OPTIONAL]
CARE_SERVICE_URL=http://care-service:3000           # [OPTIONAL]
CARE_SERVICE_TIMEOUT=5000                           # [OPTIONAL]
PLAN_SERVICE_URL=http://plan-service:3000           # [OPTIONAL]
PLAN_SERVICE_TIMEOUT=5000                           # [OPTIONAL]
GAMIFICATION_SERVICE_URL=http://gamification-service:3000  # [OPTIONAL]
GAMIFICATION_SERVICE_TIMEOUT=5000                   # [OPTIONAL]
NOTIFICATION_SERVICE_URL=http://notification-service:3000  # [OPTIONAL]
NOTIFICATION_SERVICE_TIMEOUT=5000                   # [OPTIONAL]

# Tracing
TRACING_ENABLED=false                               # [OPTIONAL] Enable distributed tracing
TRACING_EXPORTER_ENDPOINT=http://localhost:4318      # [OPTIONAL] OpenTelemetry exporter endpoint

# ---- Frontend Web (Next.js) ----
NEXT_PUBLIC_API_URL=https://api.austa.com.br        # [OPTIONAL] API base URL
NEXT_PUBLIC_API_BASE_URL=https://api.austa.com.br   # [OPTIONAL] Alias for API base URL
NEXT_PUBLIC_BASE_URL=https://app.austa.com.br       # [OPTIONAL] App base URL (SEO)
NEXT_PUBLIC_ENVIRONMENT=development                 # [OPTIONAL] Environment name
NEXT_PUBLIC_GOOGLE_CLIENT_ID=                       # [OPTIONAL][SECRET] Google OAuth (web)
NEXT_PUBLIC_APPLE_CLIENT_ID=                        # [OPTIONAL][SECRET] Apple OAuth (web)
NEXT_PUBLIC_FACEBOOK_CLIENT_ID=                     # [OPTIONAL][SECRET] Facebook OAuth (web)
NEXT_PUBLIC_DATADOG_APPLICATION_ID=                 # [OPTIONAL] Datadog RUM app ID
NEXT_PUBLIC_DATADOG_CLIENT_TOKEN=                   # [OPTIONAL][SECRET] Datadog RUM client token
NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=                  # [OPTIONAL] Git SHA for versioning
NEXT_PUBLIC_FEATURE_GAMIFICATION=true               # [OPTIONAL] Gamification feature flag

# Web Feature Flags
ENABLE_GAMIFICATION=true                            # [OPTIONAL]
ENABLE_TELEMEDICINE=true                            # [OPTIONAL]
ENABLE_AI_ASSISTANT=false                           # [OPTIONAL]
ENABLE_SOCIAL_FEATURES=false                        # [OPTIONAL]
ENABLE_WEARABLE_SYNC=true                           # [OPTIONAL]
ENABLE_CLAIM_AUTO_PROCESSING=true                   # [OPTIONAL]
ENABLE_NEW_METRICS_UI=false                         # [OPTIONAL]
ENABLE_JOURNEY_ANIMATIONS=true                      # [OPTIONAL]
ANALYTICS_TRACKING_ID=                              # [OPTIONAL] Google Analytics tracking ID

# ---- Frontend Mobile (Expo / React Native) ----
EXPO_PUBLIC_API_URL=https://api.austa.com.br        # [OPTIONAL] API base URL
EXPO_PUBLIC_USE_MOCKS=false                         # [OPTIONAL] Enable mock API responses
EXPO_PUBLIC_GOOGLE_CLIENT_ID=                       # [OPTIONAL][SECRET] Google OAuth (mobile)
EXPO_PUBLIC_APPLE_CLIENT_ID=                        # [OPTIONAL][SECRET] Apple OAuth (mobile)
EXPO_PUBLIC_FACEBOOK_CLIENT_ID=                     # [OPTIONAL][SECRET] Facebook OAuth (mobile)

# ---- Observability ----
# Sentry
SENTRY_DSN=                                         # [OPTIONAL] Sentry DSN for error tracking

# Monitoring
MONITORING_ENABLED=false                            # [OPTIONAL] Enable metrics endpoint
METRICS_PATH=/metrics                               # [OPTIONAL] Prometheus metrics path
ENABLE_METRICS=true                                 # [OPTIONAL] Enable Prometheus metrics
