# ---- Compliance / Security ----
ENCRYPTION_KEY=                                     # [OPTIONAL][SECRET] PHI encryption key (LGPD Art.46)
GDPR_ENABLED=true                                   # [OPTIONAL] Enable GDPR compliance features
LGPD_ENABLED=true                                   # [OPTIONAL] Enable LGPD compliance features
DATA_RETENTION_DAYS=730                             # [OPTIONAL] Data retention period (2 years)
SERVICE_NAME=austa-superapp                         # [OPTIONAL] Service name for logging/tracing
