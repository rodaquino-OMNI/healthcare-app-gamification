# ============================================================================
# ADR-013 AGENT GUIDE — Machine-Readable Claude-Flow Intelligence Reference
# ============================================================================
# Source: docs/ADRs/013-claude-flow-swarm-intelligence.md
# Version: 3.5.2 (ruflo)
# Updated: 2026-02-28
# Purpose: AI agent operational guide — patterns, anti-patterns, workflows
# Consumption: AI agents, swarm workers, coordinators, hook handlers
# Format: YAML (structured for LLM context injection and semantic parsing)
# ============================================================================

meta:
  adr: "013"
  title: "Claude-Flow Swarm Intelligence Agent Guide"
  cli_version: "3.5.2"
  packages: ["claude-flow", "ruflo", "@claude-flow/cli"]
  license: "MIT"
  project_namespace: "healthcare-platform"
  pattern_namespace: "patterns"
  updated: "2026-02-28"
  changelog: >
    v3.5.2 audit: Fixed hive-mind spawn flags (removed 6 non-existent flags),
    corrected two-step init→spawn workflow, documented --claude flag as primary
    mechanism, fixed dimensions 768→384, ReasoningBank 100→150, added missing
    consensus algorithms (crdt, quorum), documented missing spawn flags
    (--dry-run, --non-interactive, --dangerously-skip-permissions),
    corrected config init vs init --force distinction.

# ============================================================================
# SECTION 1: EXECUTION MODELS
# ============================================================================
# Two execution models exist. Selection depends on agent count and context.

execution_models:
  task_tool:
    label: "In-Session Task Tool (PREFERRED)"
    when: "interactive work, <= 8 agents, within Claude Code session"
    how: "Claude's native Task tool spawns parallel agents in same message"
    max_agents: 8
    benefits:
      - "no terminal context-switching"
      - "Claude controls agent lifecycle directly"
      - "parallel execution guaranteed (same message)"
      - "Agent Teams hooks fire automatically (TeammateIdle, TaskCompleted)"
      - "results available in-session for immediate validation"
    spawn_pattern: |
      mcp__claude-flow__swarm_init({ topology: "hierarchical-mesh", maxAgents: 8 })
      # NOTE: MCP wire name is "swarm_init". Parameters: topology (string), maxAgents (number), config (object).
      # The prefix mcp__claude-flow__ is added by Claude Code's MCP integration.
      Task("Coordinator", "Initialize session, coordinate via memory namespace.", "hierarchical-coordinator")
      Task("Researcher", "Analyze requirements. Store findings in memory.", "researcher")
      Task("Architect", "Design implementation based on research.", "system-architect")
      Task("Coder", "Implement following architect's design.", "coder")
      Task("Tester", "Write tests for implementation.", "tester")
      Task("Reviewer", "Review code quality and security.", "reviewer")
    critical_rule: "ALL Task calls MUST be in the SAME message for parallel execution"

  hive_mind_cli:
    label: "Hive-Mind Spawn CLI (Large Swarms)"
    when: "> 8 agents, detached execution, large parallel workloads"
    how: "TWO-STEP: init hive (once) → spawn with --claude (launches Claude Code instances)"
    max_agents: 100+

    # ── Step 1: Initialize hive (once per session) ──
    init_command: |
      claude-flow hive-mind init \
        --topology hierarchical-mesh \
        --consensus byzantine \
        --max-agents 15 \
        --memory-backend hybrid
    init_flags:
      "-t, --topology": "hierarchical | mesh | hierarchical-mesh (default) | adaptive"
      "-c, --consensus": "byzantine (default) | raft | gossip | crdt | quorum"
      "-m, --max-agents": "maximum agents (default: 15)"
      "-p, --persist": "enable persistent state (default: true)"
      "--memory-backend": "agentdb | sqlite | hybrid (default)"

    # ── Step 2: Spawn workers with Claude Code ──
    spawn_command_template: |
      claude-flow hive-mind spawn \
        --claude \
        -n {N} \
        -o "{DETAILED_OBJECTIVE}"
    spawn_flags:
      "-n, --count": "number of workers to spawn (default: 1)"
      "-r, --role": "worker (default) | specialist | scout"
      "-t, --type": "agent type (default: worker)"
      "-p, --prefix": "prefix for worker IDs (default: hive-worker)"
      "--claude": "CRITICAL — launches Claude Code instances with hive-mind coordination prompt"
      "-o, --objective": "objective for the hive mind (required with --claude)"
      "--dangerously-skip-permissions": "skip permission prompts in Claude Code (default: true)"
      "--no-auto-permissions": "disable automatic permission skipping"
      "--dry-run": "show what would be done without launching Claude Code"
      "--non-interactive": "run Claude Code in non-interactive mode"

    # ── Complete example ──
    full_example: |
      # Step 1: Initialize hive (only once per session)
      claude-flow hive-mind init -t hierarchical-mesh -c byzantine -m 15

      # Step 2: Spawn 5 Claude Code workers with objective
      claude-flow hive-mind spawn --claude -n 5 -o "Implement FHIR patient service:
        1. Create src/backend/health-service/src/fhir/patient.controller.ts
        2. Create src/backend/health-service/src/fhir/patient.service.ts
        3. Write tests in src/backend/health-service/test/fhir/patient.spec.ts
        4. Store results in memory key 'fhir-patient-impl' namespace 'healthcare-platform'"

      # Step 3: Submit additional tasks to running hive
      claude-flow hive-mind task -d "Add validation middleware for FHIR resources"

    agent_behavior_after_display: >
      STOP. Do NOT spawn Task tool agents. Do NOT poll status.
      Wait for user to execute the commands and report back.
      The --claude flag handles launching Claude Code instances automatically.

# ============================================================================
# SECTION 2: MODEL ROUTING (3-Tier — ADR-026)
# ============================================================================

model_routing:
  description: "Automatic model selection based on task complexity"
  cost_reduction: "40-60%"
  tiers:
    - tier: 1
      handler: "Agent Booster (WASM)"
      latency: "<1ms"
      cost: "$0"
      use_cases: "simple transforms (var→const, add types, rename variable)"
      models: null  # no LLM — pure WASM execution
      complexity_threshold: "<10%"
      detection: "check for [AGENT_BOOSTER_AVAILABLE] signal"
      action: "use Edit tool directly, skip LLM entirely"

    - tier: 2
      handler: "Haiku"
      latency: "~500ms"
      cost: "$0.0002"
      use_cases: "simple tasks, boilerplate, formatting, low complexity"
      models: ["claude-haiku-4-5"]
      complexity_threshold: "<30%"

    - tier: 3
      handler: "Sonnet/Opus"
      latency: "2-5s"
      cost: "$0.003-$0.015"
      use_cases: "complex reasoning, architecture, security, business logic"
      models: ["claude-sonnet-4-5", "claude-opus-4-6"]
      complexity_threshold: ">30%"

  routing_signal: "[TASK_MODEL_RECOMMENDATION]"
  rule: "always check for routing signals before spawning agents"

# ============================================================================
# SECTION 3: HOOKS SYSTEM (v3.1.0 — Local Handlers)
# ============================================================================

hooks:
  architecture: "local Node.js handlers in .claude/helpers/"
  installation: "npx @claude-flow/cli@latest init --force"
  cold_start_savings: "~2-5s per hook invocation vs old npx-based hooks"

  events:
    - event: "PreToolUse"
      matcher: "Bash"
      handler: "node .claude/helpers/hook-handler.cjs pre-bash"
      purpose: "command risk assessment before bash execution"
      timeout_ms: 5000

    - event: "PostToolUse"
      matcher: "Write|Edit|MultiEdit"
      handler: "node .claude/helpers/hook-handler.cjs post-edit"
      purpose: "edit outcome recording, co-edit pattern learning"
      timeout_ms: 10000

    - event: "UserPromptSubmit"
      matcher: null  # fires on all prompts
      handler: "node .claude/helpers/hook-handler.cjs route"
      purpose: "task routing to optimal agent/model tier"
      timeout_ms: 10000

    - event: "SessionStart"
      matcher: null
      handlers:
        - "node .claude/helpers/hook-handler.cjs session-restore"
        - "node .claude/helpers/auto-memory-hook.mjs import"
      purpose: "session state recovery, memory import"
      timeout_ms: 15000

    - event: "SessionEnd"
      matcher: null
      handler: "node .claude/helpers/hook-handler.cjs session-end"
      purpose: "state persistence, session snapshot"

    - event: "Stop"
      matcher: null
      handler: "node .claude/helpers/auto-memory-hook.mjs sync"
      purpose: "memory sync on exit"

    - event: "PreCompact"
      matchers: ["manual", "auto"]
      handlers:
        - "node .claude/helpers/hook-handler.cjs compact-manual"
        - "node .claude/helpers/hook-handler.cjs compact-auto"
        - "node .claude/helpers/hook-handler.cjs session-end"
      purpose: "context compaction, state preservation before context window reset"

    - event: "SubagentStart"
      matcher: null
      handler: "node .claude/helpers/hook-handler.cjs status"
      purpose: "agent spawn tracking"
      version_added: "3.1.0"

    - event: "TeammateIdle"
      matcher: null
      handler: "node .claude/helpers/hook-handler.cjs post-task"
      purpose: "idle agent task assignment via Agent Teams"
      version_added: "3.1.0"

    - event: "TaskCompleted"
      matcher: null
      handler: "node .claude/helpers/hook-handler.cjs post-task"
      purpose: "completion pattern training, coordinator notification"
      version_added: "3.1.0"

  cli_hooks_for_explicit_lifecycle:
    pre_task: >
      npx @claude-flow/cli@latest hooks pre-task
      --description "{task_description}"
      --task-id "{unique_id}"
      --namespace healthcare-platform
    post_task_success: >
      npx @claude-flow/cli@latest hooks post-task
      --task-id "{unique_id}"
      --status success
      --output "{results_summary}"
    post_task_failure: >
      npx @claude-flow/cli@latest hooks post-task
      --task-id "{unique_id}"
      --status failure
      --error "{error_details}"

# ============================================================================
# SECTION 4: AGENT TEAMS (v3.1.0+)
# ============================================================================

agent_teams:
  enabled: true
  env_flag: "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1"
  capabilities:
    teammate_mode: "auto"  # automatic agent coordination
    task_list: true         # shared task list across agents
    mailbox: true           # inter-agent message passing
    auto_assign_on_idle: true   # idle agents pick up queued tasks
    train_patterns_on_complete: true  # neural training on task completion
    notify_lead_on_complete: true     # coordinator notified on any agent finish
    shared_memory_namespace: "agent-teams"

# ============================================================================
# SECTION 5: MEMORY SYSTEM
# ============================================================================

memory:
  backend: "hybrid"
  rule: "use claude-flow memory for ALL temporary state. NEVER create PROGRESS.md, STATUS.md, TODO.md"

  subsystems:
    hnsw:
      enabled: true
      metric: "cosine"
      params: { M: 16, efConstruction: 200, efSearch: 100 }
      dimensions: 384

    learning_bridge:
      enabled: true
      purpose: "cross-session pattern transfer"

    memory_graph:
      enabled: true
      purpose: "relationship tracking between memory entries"

    agent_scopes:
      enabled: true
      purpose: "per-agent isolated memory namespaces"

  operations:
    store: >
      npx @claude-flow/cli@latest memory store
      --key "{key}" --value "{value}" --namespace {namespace}
    search: >
      npx @claude-flow/cli@latest memory search
      --query "{query}" --namespace {namespace} --limit {n}
    retrieve: >
      npx @claude-flow/cli@latest memory retrieve
      --key "{key}" --namespace {namespace}
    list: >
      npx @claude-flow/cli@latest memory list
      --namespace {namespace} --limit {n}

  key_conventions:
    progress: "progress-{phase}"
    patterns: "pattern-{name}"
    phase_scope: "phase-{X}-scope"
    phase_complete: "phase-{X}-complete"
    dimension_output: "dim{N}-{label}"

# ============================================================================
# SECTION 6: NEURAL LEARNING
# ============================================================================

neural:
  purpose: "train models on generated code to improve pattern recognition"
  model_types:
    moe:
      description: "Mixture of Experts — multi-domain routing"
      use_for: "generated workers, BPMN, DMN after code generation sprints"
      command: >
        npx @claude-flow/cli@latest neural train
        --modelType moe --data-source "{path}" --epochs 10 --namespace healthcare-platform

    classifier:
      description: "classification — routing, prioritization"
      use_for: "task complexity classification, agent routing decisions"
      command: >
        npx @claude-flow/cli@latest neural train
        --modelType classifier --training-data .claude-flow/training-data.jsonl --epochs 15

    transformer:
      description: "complex pattern synthesis"
      use_for: "deep code patterns, architecture learning"
      command: >
        npx @claude-flow/cli@latest neural train
        --modelType transformer --data-source "{path}" --epochs 20

  wasm_fallback:
    description: "WASM path activates when native modules unavailable"
    capabilities:
      - "MicroLoRA (256-dim, <1μs adaptation)"
      - "ScopedLoRA (17 operators)"
      - "TrajectoryBuffer"
      - "FlashAttention"
      - "AdamW Optimizer"
      - "InfoNCE Loss"
      - "SONA (256-dim, rank-4, 624k learn/s)"
    embedding_model: "all-MiniLM-L6-v2 (384-dim ONNX)"
    note: "native modules provide ~2-3x speedup but WASM is fully functional"

# ============================================================================
# SECTION 7: SONA (Self-Organizing Neural Architecture)
# ============================================================================

sona:
  description: "Reinforcement learning engine for continuous agent improvement"
  dimensions: 256
  rank: 4
  throughput: "624,000 learn/s"

  trajectory_workflow:
    begin: >
      npx @claude-flow/cli@latest hooks intelligence trajectory-start
      --task "{task_description}" --agent "{agent_type}"
    step: >
      npx @claude-flow/cli@latest hooks intelligence trajectory-step
      --trajectoryId "{id}" --action "{action}" --result "{result}" --quality {0-1}
    end: >
      npx @claude-flow/cli@latest hooks intelligence trajectory-end
      --trajectoryId "{id}" --success {true|false}

  learning_algorithms:
    - "q-learning"
    - "sarsa"
    - "double-q"
    - "actor-critic"
    - "ppo"
    - "decision-transformer"
    - "monte-carlo"
    - "td-lambda"
    - "dqn"

  task_types_for_learning:
    - "agent-routing"
    - "error-avoidance"
    - "confidence-scoring"
    - "trajectory-learning"
    - "context-ranking"
    - "memory-recall"

  ewc_plus_plus:
    description: "Elastic Weight Consolidation — prevents catastrophic forgetting"
    trigger: "trajectory-end automatically runs EWC++ consolidation"

# ============================================================================
# SECTION 8: VECTOR SEARCH (RuVector / HNSW)
# ============================================================================

vectors:
  engine: "RuVector with HNSW indexing"
  speed: "150x-12,500x faster than keyword search"
  embedding_model: "all-MiniLM-L6-v2"
  embedding_dimensions: 384

  operations:
    index: >
      npx @claude-flow/cli@latest vector index
      --source "{directory}" --namespace {namespace} --algorithm hnsw --dimensions 384
    search: >
      npx @claude-flow/cli@latest vector search
      --query "{semantic_query}" --namespace {namespace} --top-k 5
    status: "npx @claude-flow/cli@latest vector status"

  rvf_format:
    description: "RuVector File format — native binary vector store"
    operations:
      create: "rvf_create --path {file}.rvf --dimension {N} --metric cosine"
      ingest: "rvf_ingest --path {file}.rvf --entries [{id, vector, metadata}]"
      query: "rvf_query --path {file}.rvf --vector [...] --k 10"
      derive: "rvf_derive --parent {parent}.rvf --child {child}.rvf"

  hyperbolic_embeddings:
    description: "Poincaré ball embeddings for hierarchical data"
    curvature: -1
    operations: ["convert", "distance", "midpoint"]

# ============================================================================
# SECTION 9: SWARM TOPOLOGY
# ============================================================================

swarm:
  topology: "hierarchical-mesh"
  consensus: "byzantine"
  max_agents: 15
  fault_tolerance: "33% agent failure tolerance"

  topology_comparison:
    hierarchical:
      best_for: "simple tasks, clear decomposition"
      max_agents: 50
      fault_tolerance: "low"
    mesh:
      best_for: "collaborative tasks, peer review"
      max_agents: 20
      fault_tolerance: "medium"
    hierarchical_mesh:
      best_for: "complex multi-domain projects (DEFAULT)"
      max_agents: "100+"
      fault_tolerance: "high (Byzantine)"
    adaptive:
      best_for: "dynamic workloads, auto-adjusting topology"
      max_agents: "100+"
      fault_tolerance: "varies by current topology"

  initialization: >
    claude-flow hive-mind init
    --topology hierarchical-mesh --max-agents 15 --consensus byzantine

  # ── swarm vs hive-mind: Two Separate Command Groups ──
  command_groups:
    swarm:
      description: "Generic swarm coordination (init, start, stop, scale, coordinate)"
      primary_use: "V3 15-agent hierarchical mesh coordination"
      example: "claude-flow swarm init --v3-mode"
      subcommands: [init, start, status, stop, scale, coordinate]
    hive_mind:
      description: "Queen-led consensus-based multi-agent coordination with --claude support"
      primary_use: "Spawning Claude Code instances for parallel work"
      example: "claude-flow hive-mind spawn --claude -n 5 -o 'Build feature'"
      subcommands: [init, spawn, status, task, join, leave, consensus, broadcast, memory, optimize-memory, shutdown]
    relationship: >
      Both exist in parallel. 'swarm' is the generic coordination layer.
      'hive-mind' adds queen-led consensus, --claude spawning, task submission,
      and inter-worker broadcast. For most AI agent workflows, use hive-mind.

  # ── hive-mind subcommands reference ──
  hive_mind_subcommands:
    init: "initialize hive with topology, consensus, max-agents"
    spawn: "spawn workers (with --claude to launch Claude Code instances)"
    status: "show hive status, worker count, queen health"
    task: "submit tasks to the hive (-d 'description')"
    join: "join an agent to the hive mind"
    leave: "remove an agent from the hive mind"
    consensus: "manage consensus proposals and voting"
    broadcast: "broadcast a message to all workers in the hive"
    memory: "access hive shared memory"
    optimize-memory: "optimize hive memory and patterns"
    shutdown: "shutdown the hive mind"

  # ── MCP Tool Wire Names ──
  mcp_tool_names:
    description: >
      When used via MCP (from Claude Code), tools are prefixed with
      mcp__claude-flow__. The wire name (internal) drops the prefix.
    mapping:
      "mcp__claude-flow__swarm_init": { wire: "swarm_init", params: "topology, maxAgents, config" }
      "mcp__claude-flow__hive-mind_init": { wire: "hive-mind_init", params: "topology, consensus, maxAgents, persist, memoryBackend" }
      "mcp__claude-flow__hive-mind_spawn": { wire: "hive-mind_spawn", params: "count, role, type, prefix, claude, objective" }
      "mcp__claude-flow__hive-mind_status": { wire: "hive-mind_status", params: "format" }
      "mcp__claude-flow__hive-mind_task": { wire: "hive-mind_task", params: "description, priority, assignTo" }
      "mcp__claude-flow__hive-mind_broadcast": { wire: "hive-mind_broadcast", params: "message, type" }
      "mcp__claude-flow__hive-mind_memory": { wire: "hive-mind_memory", params: "action, key, value" }
      "mcp__claude-flow__hive-mind_shutdown": { wire: "hive-mind_shutdown", params: "force" }
      "mcp__claude-flow__agent_spawn": { wire: "agent_spawn", params: "type, name, config" }

# ============================================================================
# SECTION 10: PATTERNS (CORRECT BEHAVIORS)
# ============================================================================

patterns:

  memory_first:
    id: "pattern-memory-first"
    rule: "use claude-flow memory for ALL temporary state"
    correct:
      - "npx @claude-flow/cli@latest memory store --key 'progress-phase-1' --value '...' --namespace healthcare-platform"
      - "npx @claude-flow/cli@latest memory search --query 'authentication patterns' --namespace patterns"
    incorrect:
      - "creating PROGRESS.md, STATUS.md, TODO.md"
      - "echo 'status: done' > /tmp/status.txt"
      - "writing status to any markdown file"

  complete_swarm_workflow:
    id: "pattern-complete-swarm-workflow"
    description: >
      The CANONICAL workflow for delegating work to a swarm. The agent (coordinator)
      prepares everything, then displays the complete prompt for the user to paste
      in a second terminal. Agent NEVER executes the spawn command itself.
    steps:
      # ── STEP 1: PRE-TASK (agent executes in current terminal) ──
      step_1_pre_task:
        what: "Register task, store scope, verify hive is ready"
        agent_executes:
          - "npx @claude-flow/cli@latest hooks pre-task --description '{task}' --task-id '{id}' --namespace healthcare-platform"
          - "npx @claude-flow/cli@latest memory store --key 'phase-{X}-scope' --value '{scope_json}' --namespace healthcare-platform"
          - "npx @claude-flow/cli@latest hive-mind status"
        decision: "if hive not initialized → run: claude-flow hive-mind init -t hierarchical-mesh -c byzantine -m 15"

      # ── STEP 2: BUILD BENCHMARK PROMPT (agent constructs, displays in code block) ──
      step_2_build_prompt:
        what: "Construct the complete hive-mind spawn command with benchmark-style objective"
        agent_displays: >
          The agent builds a complete objective following prompt_structure pattern
          and wraps it in a hive-mind spawn command. The ENTIRE command is shown
          in a single code block for the user to copy-paste into a SECOND terminal.
        template: |
          ```bash
          claude-flow hive-mind spawn --claude -n {N} -o "
          SWARM [{NAME}]: {SCOPE_SUMMARY} | {N} workers | {FILE_COUNT} files

          MEMORY KEYS: {key1}, {key2}, {key3}
          WORKSPACE: {absolute_path}

          PRIMARY DELIVERABLES:
          1. {exact/file/path.ts}
          2. {exact/file/path.ts}

          ANTI-PATTERNS TO AVOID:
          ❌ Do NOT use hooks statusline or hive-mind status as work substitute
          ❌ Do NOT create PROGRESS.md, STATUS.md or any state markdown files
          ❌ Do NOT declare completion without EXIT GATE passing

          ━━━ EXISTING CODE (READ BEFORE WRITING) ━━━
          {MODULE}: {path}
            {ClassName}.{method}(args) → return_type

          ━━━ PHASE 1: RECON (1 worker) ━━━
          READ: {exact files}
          MAP: {what to extract — interfaces, types, patterns}
          STORE: memory key 'recon-{name}' namespace 'healthcare-platform'

          ━━━ PHASE 2: CODER ({N} workers, parallel) ━━━
          Worker-1 ({ROLE}):
            CREATE: {exact/file/path.ts}
            VALIDATE: {tsc --noEmit | jest --passWithNoTests}
            STORE: memory key 'dim1-{label}' namespace 'healthcare-platform'
            EXIT GATE: memory retrieve -k 'dim1-{label}' --namespace healthcare-platform | wc -c → must be > 500

          Worker-2 ({ROLE}):
            CREATE: {exact/file/path.ts}
            VALIDATE: {command}
            STORE: memory key 'dim2-{label}' namespace 'healthcare-platform'
            EXIT GATE: memory retrieve -k 'dim2-{label}' --namespace healthcare-platform | wc -c → must be > 500

          ━━━ PHASE 3: VERIFIER (1 worker) ━━━
          UPSTREAM GATE: verify ALL dim keys exist with > 200 bytes BEFORE proceeding
          V1: {command} → {expected}
          V2: {command} → {expected}
          STORE: memory key 'verification-{name}' namespace 'healthcare-platform'

          ━━━ EXIT CRITERIA ━━━
          ✅ All files created: find {path} -name '*.ts' | wc -l → {N}
          ✅ TypeScript compiles: tsc --noEmit --project {tsconfig} → exit 0
          ✅ Tests pass: jest --passWithNoTests {path} → exit 0
          ✅ All memory keys stored with > 500 bytes

          ROLLBACK: git checkout -- {paths}
          "
          ```

      # ── STEP 3: AGENT STOPS AND WAITS ──
      step_3_wait:
        what: "Agent displays the command and STOPS"
        agent_behavior: |
          After displaying the code block:
          1. Tell user: "Paste this command in a second terminal"
          2. STOP. Do NOT spawn Task tool agents.
          3. Do NOT poll hive-mind status.
          4. Do NOT run any more commands.
          5. Wait for user to report back with results.

      # ── STEP 4: POST-TASK (agent executes after user reports completion) ──
      step_4_post_task:
        what: "Validate results, record completion, optionally train"
        agent_executes:
          - "npx @claude-flow/cli@latest memory retrieve --key 'verification-{name}' --namespace healthcare-platform"
          - "find {path} -name '*.ts' | wc -l"
          - "npx @claude-flow/cli@latest hooks post-task --task-id '{id}' --status success --output '{summary}'"
          - "npx @claude-flow/cli@latest memory store --key 'phase-{X}-complete' --value '{completion_json}' --namespace healthcare-platform"
        optional:
          - "npx @claude-flow/cli@latest neural train --data-source '{path}' (only if significant new patterns)"

    choosing_execution_model:
      task_tool_when:
        - "<= 8 workers needed"
        - "interactive work requiring agent oversight"
        - "quick iterations where results feed next step immediately"
      hive_mind_cli_when:
        - "> 8 workers needed"
        - "long-running parallel workloads"
        - "user wants detached execution"
        - "multiple independent dimensions"

  per_worker_exit_gate:
    id: "pattern-per-worker-exit-gate"
    rule: "every worker MUST verify its own memory key was stored before declaring completion"
    template: |
      Worker-N (ROLE-NAME):
        READ: [exact file paths]
        EXECUTE: [exact grep/find/wc commands]
        STORE: memory key <key-name>, namespace <ns>
        EXIT GATE: npx @claude-flow/cli@latest memory retrieve -k <key-name> --namespace <ns> | wc -c
                   → must be > 500 (confirms key was written, not empty)
                   → IF GATE FAILS: re-execute READ+STORE steps before proceeding

  synthesizer_upstream_gate:
    id: "pattern-synthesizer-upstream-gate"
    rule: "synthesizer MUST verify ALL upstream memory keys exist and have >200 bytes BEFORE writing any report"
    template: |
      Worker-N (REPORT-SYNTHESIZER) MUST execute this check FIRST:
        REQUIRED_KEYS = [dim1-..., dim2-..., dim3-..., ...]
        FOR EACH key IN REQUIRED_KEYS:
          result = memory retrieve -k <key> --namespace <ns>
          IF result is empty or < 200 bytes:
            ABORT and store error: "SYNTHESIZER-BLOCKED: missing key <key>"
            DO NOT write any report — incomplete data produces misleading output
        ONLY IF ALL keys pass: proceed to write reports

  parallel_swarms_for_dependencies:
    id: "pattern-parallel-swarms-for-dependencies"
    rule: "if Dimension X depends on Dimension Y, they MUST be in separate sequential swarms"
    template: |
      SWARM-A (independent): DIM-1 + DIM-2
      SWARM-B (independent): DIM-4 backend + frontend
      SWARM-C (independent): DIM-5 security + deps
      [GATE: wait for A+B+C memory keys to all exist with >500 bytes each]
      SWARM-D (depends on A+B+C): DIM-3 adherence + final synthesis

  prompt_structure:
    id: "pattern-prompt-structure-benchmark"
    rule: "all swarm objectives MUST follow this structure"
    template: |
      SWARM [NAME]: [SCOPE SUMMARY] | [metrics] | [file count] | [key metric]

      MEMORY: [key1], [key2], [key3]
      WORKSPACE: [absolute path]

      PRIMARY DELIVERABLES:
      1. [exact/file/path.py]
      2. [exact/file/path.py]

      ANTI-PATTERNS TO AVOID:
      {include all anti-patterns from anti_patterns section below}

      ━━━ EXISTING CODE (READ BEFORE WRITING) ━━━
      [MODULE]: [path]
        [ClassName].[method](args) → return_type

      ━━━ PHASE 1: RECON (1 agent) ━━━
      READ: [exact files]
      MAP: [what to extract]
      OUTPUT: internal report for Phase 2

      ━━━ PHASE 2: CODER (N agents, parallel) ━━━
      CREATE/MODIFY: [exact file paths]
      VALIDATE: [command]

      ━━━ PHASE 3: VERIFIER (1 agent) ━━━
      V1: [command] → [expected result]
      V2: [command] → [expected result]

      ━━━ EXIT CRITERIA ━━━
      ✅ [criterion with measurable check]

      ROLLBACK: [recovery command if fails]
    key_rules:
      - "3-tier minimum: RECON → CODER → VERIFIER"
      - "exact file paths — no ambiguity"
      - "exact function signatures — agents don't guess APIs"
      - "explicit validation commands with expected output"
      - "anti-patterns list with ❌ prefix"
      - "exit criteria with ✅ checkmarks and grep/wc/pytest commands"
      - "rollback procedure if pass rate drops"

  delegation_threshold:
    id: "pattern-delegation-threshold"
    rules:
      - files: "1-2"
        action: "agent can edit manually (with permission)"
      - files: "3-10"
        action: "suggest swarm, offer manual as fallback"
      - files: "11+"
        action: "MANDATORY swarm delegation"
      - condition: "pattern replication (even 2 files)"
        action: "ALWAYS use swarm"

  task_complexity_auto_swarm:
    id: "pattern-task-complexity-auto-swarm"
    triggers_swarm:
      - "multiple files (3+)"
      - "new feature implementation"
      - "refactoring across modules"
      - "API changes with tests"
      - "security-related changes"
    skip_swarm:
      - "single file edits"
      - "simple bugs"
      - "config changes"

# ============================================================================
# SECTION 11: ANTI-PATTERNS (FORBIDDEN BEHAVIORS)
# ============================================================================

anti_patterns:

  agent_introspection_loop:
    id: "AP1"
    severity: "critical"
    definition: "swarm workers executing tool introspection commands (hooks statusline, memory list, hive-mind status) in place of actual work"
    symptoms:
      - "worker appears to complete but expected memory keys are missing"
      - "memory list shows only scope keys, not data keys"
      - "final synthesizer writes 0 or 1 of N expected reports"
      - "agents loop on statusline/status commands without file reads"
    root_cause: "swarm objective lacked per-worker exit gates"
    prevention: "every worker MUST have EXIT GATE that verifies memory key > 500 bytes"
    incorrect_commands:
      - "npx @claude-flow/cli@latest hooks statusline"
      - "npx @claude-flow/cli@latest hive-mind status"
    correct_commands:
      - "read_file, grep_search, run_in_terminal (find/grep/wc)"
      - "memory store with substantive content (>500 bytes)"
      - "memory retrieve + wc -c to self-verify"

  missing_upstream_gate:
    id: "AP2"
    severity: "critical"
    definition: "synthesizer starts writing output without verifying all upstream memory keys exist"
    consequence: "hallucinated report from incomplete data"
    prevention: "synthesizer MUST check ALL required keys have >200 bytes BEFORE writing"
    correct_behavior: "ABORT and store error key if any upstream key missing"

  batch_anti_pattern:
    id: "AP3"
    severity: "high"
    definition: "launching single monolithic swarm for tasks with explicit dependency ordering"
    consequence: "dependent workers get empty input, produce empty findings"
    prevention: "split into parallel swarms for independent dims + dependent synthesis swarm"
    rule: "if Dimension X lists depends_on [DIM-Y], it MUST be in a separate later swarm"

  queen_as_coder:
    id: "AP4"
    severity: "high"
    definition: "agent acting as primary code generator instead of delegating to swarm"
    symptoms:
      - "agent writes code directly using replace_string_in_file"
      - "agent generates code in chat asking user to copy-paste"
      - "agent creates files sequentially over hours"
    consequences:
      - "inefficient: manual edits take 10-20x longer than swarm"
      - "error-prone: introduces inconsistencies"
      - "no learning: patterns not captured in neural system"
      - "context limit: runs out of tokens after 20-30 manual edits"
    correct_behavior: "prepare swarm command, execute hooks, validate results"
    agent_role: "architect + planner + coordinator, NOT coder"

  markdown_state_files:
    id: "AP5"
    severity: "medium"
    definition: "creating PROGRESS.md, STATUS.md, TODO.md for tracking work"
    correct: "use claude-flow memory system"
    reason: "memory is semantic-searchable, versioned, namespaced, auto-cleaned"

  automated_cli_execution:
    id: "AP6"
    severity: "medium"
    definition: "agent executing hive-mind spawn command directly in its own terminal"
    incorrect:
      - "running spawn in agent's bash via run_in_terminal (blocks dialog, steals terminal)"
      - "heredoc to file then cat (extra steps, escaping issues)"
      - "background execution with & (lost output, no monitoring)"
      - "running spawn without --claude (spawns idle workers with no objective)"
    correct: |
      Display the COMPLETE hive-mind spawn --claude command in a code block.
      User pastes it in a SECOND terminal. The --claude flag handles:
      - Launching Claude Code instances automatically
      - Injecting the hive-mind coordination prompt
      - Setting up inter-agent communication
      Agent's role: build the command, display it, STOP, wait for user.
    reason: >
      Agent's terminal is shared with Claude Code. Running spawn there blocks
      the conversation. The --claude flag automates what was previously manual
      (no need for user to manage individual Claude instances). But the spawn
      command itself must run in a SEPARATE terminal to avoid conflicts.

  npx_hooks:
    id: "AP7"
    severity: "medium"
    definition: "using npx-based hook commands instead of local handlers"
    deprecated: "npx claude-flow@version hooks pre-command"
    current: "node .claude/helpers/hook-handler.cjs pre-bash"
    reason: "2-5s cold-start savings per invocation, no version fragmentation"

# ============================================================================
# SECTION 12: ADVANCED FEATURES
# ============================================================================

advanced_features:

  agent_booster_wasm:
    description: "Ultra-fast code editing (352x faster than cloud APIs, $0 cost)"
    latency: "<1ms"
    use_cases: "simple transforms, variable renames, type additions"
    detection_signal: "[AGENT_BOOSTER_AVAILABLE]"
    action: "use Edit tool directly, skip LLM"
    capabilities:
      - "precise code edits using '// ... existing code ...' markers"
      - "batch edits across multiple files"
      - "markdown parsing for multi-file refactoring"

  flash_attention:
    description: "Optimized attention computation for large context"
    speedup: "2.49x-7.47x"
    mode: "flash"
    command: >
      npx @claude-flow/cli@latest hooks intelligence attention
      --query "{query}" --mode flash --topK {n}

  mixture_of_experts:
    description: "MoE routing for specialized task distribution"
    mode: "moe"
    command: >
      npx @claude-flow/cli@latest hooks intelligence attention
      --query "{query}" --mode moe --topK {n}

  hyperbolic_attention:
    description: "Poincaré ball attention for hierarchical relationships"
    mode: "hyperbolic"
    command: >
      npx @claude-flow/cli@latest hooks intelligence attention
      --query "{query}" --mode hyperbolic --topK {n}

  reasoning_bank:
    description: "stores successful problem-solving approaches for retrieval"
    operations:
      store: >
        agentdb_pattern_store --sessionId "{id}" --task "{task}"
        --reward {0-1} --success {bool} --input "{context}" --output "{solution}"
      search: >
        agentdb_pattern_search --task "{task}" --k 5 --onlySuccesses true
      stats: >
        agentdb_pattern_stats --task "{task}" --k 5

  tensor_compress:
    description: "up to 10x memory savings for pattern storage"
    levels: ["none", "half", "pq8", "pq4", "binary"]
    command: "npx @claude-flow/cli@latest hooks compress"

  claims_system:
    description: "work authorization and issue ownership for multi-agent coordination"
    operations:
      claim: "claims_claim --issueId {id} --claimant {agent}"
      release: "claims_release --issueId {id} --claimant {agent}"
      handoff: "claims_handoff --issueId {id} --from {agent1} --to {agent2}"
      steal: "claims_steal --issueId {id} --stealer {agent}"
      board: "claims_board"
      rebalance: "claims_rebalance --dryRun true"

  diff_analysis:
    description: "git diff risk assessment, classification, reviewer suggestion"
    operations:
      analyze: "analyze_diff --ref HEAD --includeFileRisks true"
      risk: "analyze_diff-risk --ref HEAD"
      classify: "analyze_diff-classify --ref HEAD"
      reviewers: "analyze_diff-reviewers --ref HEAD --limit 5"

  co_edit_patterns:
    description: "learn which files are commonly edited together"
    record: "hooks coedit_record --primary_file {file} --related_files [{files}]"
    suggest: "hooks coedit_suggest --file {file} --top_k 5"

  error_learning:
    description: "record errors and fixes for future suggestions"
    record: "hooks error_record --error '{msg}' --fix '{fix}' --file {file}"
    suggest: "hooks error_suggest --error '{msg}'"

  security_scanning:
    description: "parallel vulnerability scan"
    command: "hooks security_scan --files [{file_list}]"

  ast_analysis:
    description: "parse file AST, extract symbols, imports, complexity"
    analyze: "hooks ast_analyze --file {path}"
    complexity: "hooks ast_complexity --files [{paths}] --threshold 10"

  graph_analysis:
    description: "code boundary and community detection"
    mincut: "hooks graph_mincut --files [{paths}]"
    cluster: "hooks graph_cluster --files [{paths}] --method louvain"

  rag_context:
    description: "retrieval-augmented generation with optional reranking"
    command: "hooks rag_context --query '{query}' --rerank true --top_k 5"

  git_churn:
    description: "find hot spots by analyzing git change frequency"
    command: "hooks git_churn --days 30 --top 10"

  enhanced_routing:
    description: "routing using AST complexity + coverage + diff signals"
    command: "hooks route_enhanced --task '{task}' --file {path}"

# ============================================================================
# SECTION 13: WORKER DAEMON SYSTEM
# ============================================================================

workers:
  description: "background analysis workers dispatched via hooks"
  triggers:
    ultralearn: "deep knowledge acquisition and learning"
    optimize: "performance optimization analysis"
    consolidate: "memory consolidation"
    predict: "predictive analysis"
    audit: "code audit"
    map: "codebase mapping and architecture analysis"
    preload: "context preloading"
    deepdive: "deep code analysis and examination"
    document: "documentation generation"
    refactor: "refactoring opportunities"
    benchmark: "performance benchmarking"
    testgaps: "test coverage gap analysis"

  dispatch_command: >
    npx @claude-flow/cli@latest hooks worker dispatch --trigger {trigger}

  presets: ["quick-scan", "deep-analysis", "security-scan", "learning", "api-docs", "test-analysis"]

# ============================================================================
# SECTION 14: BOOTSTRAP PROTOCOL
# ============================================================================
# IMPORTANT: This section documents the COMPLETE initialization sequence.
# The sequence was validated on 2026-02-28 against v3.5.2.
#
# KEY LEARNING: Do NOT use `init --force` if you already have a customized
# .claude/settings.json or .claude-flow/config.yaml — it overwrites them.
# Use the granular commands below instead.

bootstrap:
  description: "mandatory initialization sequence for every new session"

  prerequisites:
    node: ">= 20.0.0"           # v22 LTS recommended
    npm: ">= 10.0.0"
    claude_code_cli: ">= 2.0.0" # `claude --version`
    disk_space: "500MB"          # For memory.db + neural models

  phase_0_cache_clear:
    description: "Clear stale npx cache and install globally — REQUIRED when upgrading versions"
    why: >
      npx caches old versions and may timeout on 757+ packages (SIGTERM).
      Global install is PREFERRED: it avoids cold-start penalty on every command
      and ensures the correct version is always used.
    steps:
      - "rm -rf ~/.npm/_npx/*"
      - "npm install -g @claude-flow/cli@latest"
      - "claude-flow --version"
    expected: "claude-flow v3.5.2"
    note: "zsh may prompt 'remove?' for each dir — answer 'y'"

  phase_a_system_init:
    description: "Initialize core subsystems (config, memory, daemon)"
    steps:
      - command: "claude-flow config init --force"
        creates: ["claude-flow.config.json", ".claude-flow/config.yaml", ".claude-flow/ directory tree"]
        note: >
          'config init' creates claude-flow.config.json (SystemConfigSchema-validated)
          and .claude-flow/ directory. This is DIFFERENT from 'claude-flow init --force'
          which creates 115 files including .claude/settings.json, .claude/helpers/, CLAUDE.md.
          Use 'config init' for config only; use 'init --force' for full scaffold (OVERWRITES existing files).
        flags:
          "--force, -f": "overwrite existing configuration"
          "--sparc": "initialize with SPARC methodology (specification, pseudocode, architecture, refinement, completion)"
          "--v3": "initialize V3 configuration (default: true)"
      - command: "claude-flow memory init --force --verbose"
        creates: [".swarm/memory.db"]
        verification: "6/6 tests should pass (tables, ONNX, HNSW, patterns, temporal, queries)"
      - command: "claude-flow daemon start"
        creates: [".claude-flow/daemon.pid", ".claude-flow/daemon.log"]
        note: "Runs in background. Check: daemon status. Stop: daemon stop"
      - command: "claude-flow doctor --verbose"
        expected: "10+ passed, 0-2 warnings, 0-1 failures (disk space only)"
    warning: "init --force OVERWRITES .claude/settings.json and CLAUDE.md — backup first"

  phase_b_intelligence:
    description: "Train neural patterns and build agent configs"
    steps:
      - command: "claude-flow hooks pretrain --model-type moe --epochs 3"
        what_it_does: "Scans 84+ files, extracts 30+ patterns, learns 16+ strategies"
        duration: "~1-3 seconds"
      - command: "claude-flow hooks build-agents --verbose"
        creates: ["agents/coder.yaml", "agents/architect.yaml", "agents/tester.yaml",
                   "agents/security-architect.yaml", "agents/reviewer.yaml"]
        note: "Writes to PROJECT_ROOT/agents/, NOT .claude-flow/agents/ — this is correct"
      - command: "claude-flow neural train -p coordination"
        what_it_does: "50 epochs, builds ReasoningBank (150 patterns)"
        creates: [".claude-flow/neural/patterns.json", ".claude-flow/neural/stats.json"]
    model_types:
      moe: "Mixture of Experts — routes to specialized sub-models (recommended)"
      transformer: "Full transformer attention"
      classifier: "Pattern classification"

  phase_c_daemon_workers:
    description: "Dispatch background analysis workers"
    steps:
      - command: "claude-flow hooks worker dispatch --trigger map"
        purpose: "Codebase mapping and architecture analysis"
      - command: "claude-flow hooks worker dispatch --trigger deepdive"
        purpose: "Deep analysis of complex code patterns"
      - command: "claude-flow hooks worker dispatch --trigger ultralearn"
        purpose: "Neural training sequence, pattern consolidation"
    all_workers: [map, deepdive, ultralearn, audit, optimize, consolidate,
                  testgaps, document, refactor, benchmark]
    note: "Workers run async; use 'hooks worker status' to check"

  phase_d_hive_mind:
    description: "Initialize queen-led swarm coordination"
    command: >
      claude-flow hive-mind init
      --topology hierarchical-mesh --max-agents 15 --consensus byzantine
    topologies:
      hierarchical: "Queen controls all workers (recommended for coding)"
      mesh: "Peer-to-peer coordination"
      hierarchical-mesh: "Queen + peer groups (recommended for complex analysis, DEFAULT)"
      adaptive: "Dynamic topology based on workload"
    consensus_algorithms:
      byzantine: "BFT — tolerates f faults with 3f+1 agents (most robust, DEFAULT)"
      raft: "Leader election — fast, good for stable teams"
      gossip: "Epidemic protocol — eventually consistent"
      crdt: "Conflict-free replicated data — automatic merge"
      quorum: "Simple majority voting"
    additional_flags:
      "--persist": "enable persistent state (default: true)"
      "--memory-backend": "agentdb | sqlite | hybrid (default)"
    creates: [".claude-flow/hive-mind/state.json"]

  phase_e_verification:
    description: "Final health check after bootstrap"
    commands:
      - "claude-flow doctor --verbose"
      - "claude-flow neural status"
      - "claude-flow memory stats"
    expected_doctor: "10+ passed, 0-2 warnings"
    known_cosmetic_warnings:
      - "No API keys — not needed for local Claude Code CLI usage"
      - "Disk space — hardware constraint, not actionable"

  quickstart_copy_paste:
    description: "Minimal copy-paste sequence for a complete bootstrap"
    sequence:
      - "rm -rf ~/.npm/_npx/*"
      - "npm install -g @claude-flow/cli@latest"
      - "claude-flow --version"
      - "claude-flow config init --force"
      - "claude-flow memory init --force --verbose"
      - "claude-flow daemon start"
      - "claude-flow hooks pretrain --model-type moe --epochs 3"
      - "claude-flow hooks build-agents --verbose"
      - "claude-flow neural train -p coordination"
      - "claude-flow hive-mind init --topology hierarchical-mesh --max-agents 15 --consensus byzantine"
      - "claude-flow doctor --verbose"
    note_for_ai_agents: >
      Execute commands ONE AT A TIME. Wait for each to fully complete before
      running the next. Terminal commands that receive input too quickly will
      SIGTERM/exit 130. npx-based execution may timeout on 757+ packages —
      prefer global install via npm install -g.

# ============================================================================
# SECTION 14b: .claude-flow/ DIRECTORY STRUCTURE & EXPECTED STATE
# ============================================================================
# CRITICAL: Some directories are INTENTIONALLY EMPTY after bootstrap.
# This section documents which directories should have files and which are
# lazy-initialized placeholders.

directory_structure:
  description: >
    The `config init` command creates the directory scaffold. NOT all directories
    are populated at init time. Many are lazy-initialized — they receive content
    only when their corresponding feature is first used during actual work.
    Empty directories after bootstrap is EXPECTED BEHAVIOR.

  ".claude-flow/":
    populated_at_init:
      config.yaml: "Runtime config — always present after config init"
      agents.json: "Agent registry store — populated by hive-mind init"
      daemon-state.json: "Worker run counts — populated by daemon start"
      daemon.pid: "Daemon process ID — populated by daemon start"
      daemon.log: "Daemon log output — populated by daemon start"
      CAPABILITIES.md: "Feature documentation — generated by config init"
      ".gitignore": "Excludes transient files from git"
      ".trend-cache.json": "Trend analysis cache"

    data/:
      populated_by: "hooks, memory operations, intelligence system"
      files: ["auto-memory-store.json", "graph-state.json",
              "intelligence-snapshot.json", "pending-insights.jsonl",
              "ranked-context.json"]
      status: "Populated after pretrain and worker dispatch"

    neural/:
      populated_by: "neural train command"
      files: ["patterns.json", "stats.json"]
      status: "Populated after 'neural train -p coordination'"

    sessions/:
      populated_by: "session-start hook and daemon"
      files: ["current.json", "session-{timestamp}.json"]
      status: "Populated automatically during sessions"

    hive-mind/:
      populated_by: "hive-mind init"
      files: ["state.json"]
      status: "Populated after hive-mind init"

    metrics/:
      populated_by: "hooks, workers, learning system"
      files: ["learning.json", "swarm-activity.json", "v3-progress.json"]
      status: "Populated during active usage"

    security/:
      populated_by: "security audit worker"
      files: ["audit-status.json"]
      status: "Populated after audit worker runs"

    logs/:
      populated_by: "daemon, error logging"
      status: "Populated during daemon operation"

    # ═══ INTENTIONALLY EMPTY AFTER BOOTSTRAP ═══

    agents/:
      populated_by: "agent lifecycle operations (spawn, create)"
      purpose: "Runtime agent state storage (store.json created on first agent spawn)"
      why_empty: >
        This directory stores runtime agent instance state — NOT agent config
        templates. Agent config YAMLs go in PROJECT_ROOT/agents/. The store.json
        file appears here only when agents are spawned via hive-mind or swarm
        commands during actual task execution.
      status: "EMPTY AFTER BOOTSTRAP — this is expected"
      will_contain: "store.json (agent records with status, health, task counts)"

    hooks/:
      populated_by: "custom hook definitions (user-created)"
      purpose: "Custom hook handler scripts"
      why_empty: >
        Default hooks are defined in .claude/settings.json and handled by
        .claude/helpers/hook-handler.cjs. This directory is for optional
        custom hook overrides that users write themselves. Claude Flow V3
        does not generate files here automatically.
      status: "EMPTY AFTER BOOTSTRAP — this is expected"
      will_contain: "User-created hook scripts (e.g., custom-pre-edit.sh)"

    workflows/:
      populated_by: "workflow definitions (user-created or future feature)"
      purpose: "Reusable workflow templates for multi-step tasks"
      why_empty: >
        Workflow definitions are a V3 feature still in development. The directory
        is scaffolded for forward compatibility. Users can manually create
        workflow YAML files here for custom multi-step automation.
      status: "EMPTY AFTER BOOTSTRAP — this is expected"
      will_contain: "Workflow YAML definitions (future feature)"

    learning/:
      populated_by: "learning-service.mjs (from .claude/helpers/)"
      purpose: "Cross-session learning persistence (patterns.db, metrics)"
      why_empty: >
        The learning service creates files here on first pattern promotion.
        Patterns start in short-term memory (in-memory) and are promoted to
        long-term storage after 3+ uses. Until significant patterns accumulate
        from actual coding work, this directory stays empty. The initial
        pretrain data goes to neural/ and data/ directories instead.
      status: "EMPTY AFTER BOOTSTRAP — this is expected"
      will_contain: "patterns.db, learning-metrics.json (after sustained usage)"

  # ═══ OTHER KEY DIRECTORIES (outside .claude-flow/) ═══

  "agents/":
    location: "PROJECT_ROOT/agents/"
    populated_by: "hooks build-agents"
    contains: ["coder.yaml", "architect.yaml", "tester.yaml",
               "security-architect.yaml", "reviewer.yaml"]
    note: "These are agent CONFIG TEMPLATES, not runtime state"

  ".swarm/":
    location: "PROJECT_ROOT/.swarm/"
    populated_by: "memory init"
    contains: ["memory.db"]
    note: "SQLite + HNSW vector database (the main persistent memory)"

  ".claude/":
    location: "PROJECT_ROOT/.claude/"
    populated_by: "init --force (NOT config init — these are different commands)"
    contains: ["settings.json", "helpers/", "commands/", "agents/"]
    note: "Claude Code integration layer — hooks, permissions, statusline. Created by 'init --force' which generates 115 files."

# ============================================================================
# SECTION 14c: CONFIGURATION FILES REFERENCE
# ============================================================================

config_reference:
  description: "Four-layer configuration architecture in Claude Flow V3"

  layer_0_schema:
    file: "claude-flow.config.json"
    purpose: "SystemConfigSchema-validated shim — checked by doctor, read by CLI core"
    format: JSON
    created_by: "claude-flow config init"
    schema_source: "@claude-flow/shared/dist/core/config/schema.js (Zod)"
    required_fields:
      orchestrator: "REQUIRED — { session, health, lifecycle }"
      memory: "{ type: 'hybrid' (NOT 'backend'), path, agentdb: { dimensions, indexType } }"
      mcp: "{ name, transport: { type: 'stdio' } }"
      swarm: "OPTIONAL — { topology, maxAgents, autoScale: { enabled, minAgents, maxAgents, ... }, coordination }"
    key_gotchas:
      - "'orchestrator' is REQUIRED — missing it causes Zod validation error"
      - "'swarm.autoScale' must be an OBJECT not boolean — { enabled: true, minAgents: 2, ... }"
      - "use 'memory.type' NOT 'memory.backend'"
      - "extra root keys like 'neural', 'hooks', '$schema', 'version' are NOT in schema"
    adapter: "config-adapter.js converts between SystemConfig ↔ V3Config via systemConfigToV3Config()"

  layer_1_runtime:
    file: ".claude-flow/config.yaml"
    purpose: "THE main runtime config — single source of truth for V3"
    format: YAML
    read_by:
      - "auto-memory-hook.mjs (learningBridge, memoryGraph, agentScopes)"
      - "daemon (workers, schedules, autoStart)"
      - "hooks (preTask, postTask, trainOnEdit)"
      - "hive-mind (topology, consensus)"
      - "MCP server (transport, port, capabilities)"
    sections: [version, swarm, hiveMind, memory, neural, embeddings,
               hooks, daemon, mcp, agents, learning, orchestrator,
               verification, security, logging, project]
    schema_source: "@claude-flow/shared/dist/core/config/schema.js (Zod validated)"
    why_yaml: >
      V3 uses YAML (not JSON) for runtime config because: (1) YAML supports
      comments essential for documenting 16 config sections, (2) auto-memory-hook.mjs
      explicitly reads .claude-flow/config.yaml, (3) COMPONENTS.md states 'config.yaml
      configures V3 runtime'. Note: claude-flow.config.json (layer_0) also exists
      as the SystemConfigSchema-validated entry point — both files coexist.

  layer_2_hooks:
    file: ".claude/settings.json"
    purpose: "Claude Code integration — hooks, permissions, env vars"
    format: JSON
    key_sections:
      hooks: "PreToolUse, PostToolUse, UserPromptSubmit, SessionStart/End, Stop"
      permissions: "allow/deny rules for Bash, MCP, file reads"
      env: "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1, CLAUDE_FLOW_V3_ENABLED=true"
      claudeFlow: "Mirrors key config.yaml settings"

  layer_3_mcp:
    file: ".mcp.json"
    purpose: "MCP server connection for tool integration"
    format: JSON
    content:
      server: "claude-flow"
      command: "npx @claude-flow/cli@latest mcp start"
      env_vars:
        CLAUDE_FLOW_MODE: "v3"
        CLAUDE_FLOW_HOOKS_ENABLED: "true"
        CLAUDE_FLOW_TOPOLOGY: "hierarchical-mesh"
        CLAUDE_FLOW_MAX_AGENTS: "15"
        CLAUDE_FLOW_MEMORY_BACKEND: "hybrid"

# ============================================================================
# SECTION 14d: TROUBLESHOOTING
# ============================================================================

troubleshooting:
  stale_version:
    symptom: "doctor shows 'Version Freshness' warning or old alpha number"
    fix: "rm -rf ~/.npm/_npx/* && npm install -g @claude-flow/cli@latest && claude-flow --version"

  config_warning:
    symptom: "doctor shows 'No config file (using defaults)'"
    fix: "claude-flow config init && edit claude-flow.config.json to conform to SystemConfigSchema"
    note: >
      NOT cosmetic — config init creates claude-flow.config.json which must conform to
      SystemConfigSchema (Zod). Key gotchas: 'orchestrator' is required, 'swarm.autoScale'
      must be an object (not boolean), use 'memory.type' (not 'memory.backend').
      Schema source: @claude-flow/shared/dist/core/config/schema.js

  daemon_not_running:
    symptom: "doctor shows 'Daemon Status: Not running'"
    fix: "npx @claude-flow/cli@latest daemon start"

  sona_not_loaded:
    symptom: "neural status shows 'SONA Engine: Not loaded'"
    fix: "npx @claude-flow/cli@latest neural train -p coordination"
    note: "SONA is optional; SONA Coordinator + ReasoningBank are sufficient"

  wasm_fallback:
    symptom: "attention.FlashAttention is not a constructor"
    impact: "None — falls back to JS implementation automatically"
    fix: "No action needed"

  memory_empty:
    symptom: "memory stats shows 0 entries after init"
    explanation: "Normal — entries accumulate during actual usage"
    quick_test: "npx @claude-flow/cli@latest memory store --key test --value hello --namespace test"

  api_keys_warning:
    symptom: "doctor shows 'No API keys found'"
    impact: "Not needed for local Claude Code CLI usage"
    fix: "Set ANTHROPIC_API_KEY only if using API directly"

  timeout_on_macos:
    symptom: "Commands exit with code 143 or 'timeout not found'"
    explanation: "macOS does not ship with GNU timeout"
    workaround: "Background long commands with & and sleep, or use gtimeout from coreutils"

  yaml_corruption:
    symptom: "config.yaml has garbled/merged content"
    explanation: "Some editor tools can corrupt YAML during write"
    fix: "Delete the file and re-create via terminal: cat > .claude-flow/config.yaml << 'EOF'"

  empty_claude_flow_dirs:
    symptom: ".claude-flow/agents, hooks, workflows, learning are empty"
    explanation: "Expected behavior — see directory_structure section above"
    fix: "No action needed — these populate lazily during actual work"

# ============================================================================
# SECTION 15: PHASE WORKFLOW (Standard Execution Cycle)
# ============================================================================

phase_workflow:
  description: >
    Standard phase execution cycle for all swarm tasks.
    This is the MASTER WORKFLOW that the coordinator agent follows.
    Each phase is a complete pre-task → prompt → paste → post-task cycle.
  
  overview: |
    ┌─────────────────────────────────────────────────────┐
    │  PHASE N EXECUTION CYCLE                            │
    │                                                     │
    │  1. PRE-TASK  → agent runs hooks, stores scope      │
    │  2. PROMPT    → agent builds benchmark-style prompt  │
    │  3. DISPLAY   → agent shows spawn command in ```     │
    │  4. ── STOP ──→ user pastes in second terminal      │
    │  5. WAIT      → agent waits for user notification    │
    │  6. VALIDATE  → agent runs find/wc/grep checks      │
    │  7. POST-TASK → agent records completion             │
    │  8. NEXT      → repeat for Phase N+1                │
    └─────────────────────────────────────────────────────┘

  detailed_steps:
    step_1_pre_task:
      agent_runs:
        - "npx @claude-flow/cli@latest hooks pre-task --description '{task}' --task-id 'phase-{X}' --namespace healthcare-platform"
        - "npx @claude-flow/cli@latest memory store --key 'phase-{X}-scope' --value '{scope}' --namespace healthcare-platform"
      purpose: "register task in lifecycle system, store scope for workers to read"

    step_2_build_prompt:
      agent_does: "constructs the benchmark-style objective following prompt_structure pattern"
      includes:
        - "SWARM header with scope, metrics, file count"
        - "MEMORY keys workers will write to"
        - "WORKSPACE absolute path"
        - "PRIMARY DELIVERABLES with exact file paths"
        - "ANTI-PATTERNS block (all from section 11)"
        - "EXISTING CODE references (read before write)"
        - "3-tier phases: RECON → CODER → VERIFIER"
        - "Per-worker EXIT GATES with memory retrieve + wc -c"
        - "EXIT CRITERIA with measurable commands"
        - "ROLLBACK command"

    step_3_display:
      agent_does: |
        Wraps the objective in:
        ```bash
        claude-flow hive-mind spawn --claude -n {N} -o "{COMPLETE_OBJECTIVE}"
        ```
        Tells user: "Paste this in a second terminal."

    step_4_stop:
      agent_behavior: "STOP. No more tool calls. No polling. No Task spawns."
      wait_for: "User returns with results or reports errors."

    step_5_validate:
      agent_runs:
        - "find {path} -name '*.ts' -newer {reference} | wc -l"
        - "npx @claude-flow/cli@latest memory retrieve --key 'verification-{name}' --namespace healthcare-platform"
        - "tsc --noEmit --project {tsconfig} (if TypeScript)"
        - "jest --passWithNoTests {path} (if tests expected)"

    step_6_post_task:
      agent_runs:
        - "npx @claude-flow/cli@latest hooks post-task --task-id 'phase-{X}' --status success --output '{summary}'"
        - "npx @claude-flow/cli@latest memory store --key 'phase-{X}-complete' --value '{results}' --namespace healthcare-platform"
      optional: "npx @claude-flow/cli@latest neural train --data-source '{path}' (if significant patterns)"

    step_7_next_phase:
      check: "are there more phases? if yes, repeat from step_1 with phase X+1"
      gate: "if next phase depends on this one, verify memory keys exist before proceeding"

  multi_swarm_sequencing:
    description: "when phases have dependencies, use sequential swarms with gates"
    example: |
      SWARM-A (Phase 1+2, independent): dim-1 + dim-2 workers
      SWARM-B (Phase 3+4, independent): dim-3 + dim-4 workers
      ── GATE: verify all SWARM-A + SWARM-B memory keys > 500 bytes ──
      SWARM-C (Phase 5, depends on A+B): synthesis + verification workers

# ============================================================================
# SECTION 16: TOOL CHECKLIST (ALL must be used)
# ============================================================================

tool_checklist:
  - tool: "memory"
    purpose: "store/search context, patterns, progress"
    mandatory: true
  - tool: "neural"
    purpose: "train models on generated code"
    mandatory: true
  - tool: "vector"
    purpose: "semantic search across documentation"
    mandatory: true
  - tool: "hive-mind"
    purpose: "swarm coordination"
    mandatory: true
  - tool: "hooks"
    purpose: "lifecycle tracking (10 hook types with local handlers)"
    mandatory: true
  - tool: "patterns"
    purpose: "pattern library management"
    mandatory: true
  - tool: "learn"
    purpose: "extract patterns from existing code"
    mandatory: true
  - tool: "validate"
    purpose: "quality checks on generated code"
    mandatory: true
  - tool: "analyze"
    purpose: "gap analysis vs requirements"
    mandatory: true
  - tool: "agent-teams"
    purpose: "automatic task coordination"
    mandatory: true
    version: "3.1.0+"
  - tool: "embeddings"
    purpose: "vector embeddings (75x faster with agentic-flow)"
    mandatory: true
    version: "3.1.0+"
  - tool: "claims"
    purpose: "claims-based work authorization"
    mandatory: true
    version: "3.1.0+"

# ============================================================================
# SECTION 17: CONFIGURATION FILES (see also Section 14c for full reference)
# ============================================================================

configuration:
  project_level:
    - file: ".claude/settings.json"
      purpose: "hooks, permissions, Agent Teams, claudeFlow config"
      init_force_overwrites: true

    - file: ".claude/settings.local.json"
      purpose: "project-specific permissions, enabled MCP servers"
      init_force_overwrites: false

    - file: ".mcp.json"
      purpose: "MCP server definitions"
      init_force_overwrites: false

    - file: "CLAUDE.md"
      purpose: "agent behavioral instructions"
      init_force_overwrites: true

    - file: ".claude/helpers/"
      purpose: "local hook handlers (41 files)"
      init_force_overwrites: true

    - file: ".claude/agents/"
      purpose: "agent type definitions (23 agents)"
      init_force_overwrites: true

    - file: ".claude-flow/"
      purpose: "runtime data (config, logs, sessions)"
      init_force_overwrites: true

  global_level:
    - file: "~/.claude/settings.json"
      purpose: "global hooks, permissions, effortLevel"
    - file: "~/.mcp.json"
      purpose: "global MCP servers (must include claude-flow)"

# ============================================================================
# SECTION 18: AGENT ROLE DEFINITIONS
# ============================================================================

agent_roles:
  coordinator:
    role: "architect + planner + coordinator"
    responsibilities:
      - "design solutions, define scope, plan execution"
      - "break down tasks, estimate effort, sequence dependencies"
      - "prepare swarm commands, execute hooks, validate results"
    does_not: "write production code manually (swarms do this)"

  available_agent_types:
    core: ["coder", "reviewer", "tester", "planner", "researcher"]
    specialized: ["security-architect", "security-auditor", "memory-specialist", "performance-engineer"]
    swarm: ["hierarchical-coordinator", "mesh-coordinator", "adaptive-coordinator"]
    github: ["pr-manager", "code-review-swarm", "issue-tracker", "release-manager"]
    sparc: ["sparc-coord", "sparc-coder", "specification", "pseudocode", "architecture"]

# ============================================================================
# SECTION 19: COMPLIANCE VERIFICATION COMMANDS
# ============================================================================

compliance:
  description: "run these before any code generation sprint"
  checks:
    - command: "claude-flow --version"
      expected: ">= 3.5.0"
    - command: "ls .claude/helpers/hook-handler.cjs .claude/helpers/auto-memory-hook.mjs"
      expected: "both files must exist"
    - command: "grep 'CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS' .claude/settings.json"
      expected: "must show '1'"
    - command: "npx @claude-flow/cli@latest vector status"
      expected: "RuVector available"
    - command: "npx @claude-flow/cli@latest memory list --namespace healthcare-platform"
      expected: "memory operational"
    - command: "npx @claude-flow/cli@latest neural list"
      expected: "models trained"
    - command: "npx @claude-flow/cli@latest hive-mind status"
      expected: "hive-mind initialized"

# ============================================================================
# END OF AGENT GUIDE
# ============================================================================
